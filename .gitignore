# ==========================================================
# Sysadmin Security Lab - Global .gitignore
# ==========================================================
# Purpose:
# Ignore operating system files, IDE settings, runtime
# artifacts, build outputs, secrets, and temporary files
# across a multi-language DevSecOps repository.
# ==========================================================

# ==========================================================
# Operating System Files
# ==========================================================

.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini
*.lnk

# ==========================================================
# Editors / IDEs
# ==========================================================

.vscode/
.idea/
*.swp
*.swo
*~
*.orig

# ==========================================================
# Python
# ==========================================================

__pycache__/
**/__pycache__/

*.py[cod]
*.pyo
*.pyd
*$py.class

.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.nox/

.coverage
.coverage.*
htmlcov/

.eggs/
*.egg
*.egg-info/
pip-wheel-metadata/

# Virtual environments

.venv/
venv/
env/
ENV/

# ==========================================================
# Node / JavaScript
# ==========================================================

node_modules/

npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ==========================================================
# Java / Kotlin / Scala
# ==========================================================

.gradle/
build/
target/

*.class
*.jar
*.war
*.ear
*.iml

# ==========================================================
# Go
# ==========================================================

bin/
vendor/

*.exe
*.exe~
*.dll
*.so
*.dylib

# ==========================================================
# Rust
# ==========================================================

target/

# Uncomment for libraries only
# Cargo.lock

# ==========================================================
# .NET
# ==========================================================

bin/
obj/

*.user
*.suo

# ==========================================================
# Ruby
# ==========================================================

.bundle/
vendor/bundle/

*.gem

# ==========================================================
# PHP
# ==========================================================

vendor/

# ==========================================================
# Vagrant / Virtual Labs
# ==========================================================

.vagrant/

# ==========================================================
# Logs / Runtime Data
# ==========================================================

*.log
*.log.*
*.pid
*.pid.lock
*.seed

*.sqlite
*.sqlite3
*.db

# ==========================================================
# Secrets / Sensitive Data
# ==========================================================

.env
.env.*
!.env.example

*.key
*.pem
*.secret
*.token
*.p12
*.pfx

credentials.*
config.local.json
config.*.local.json

vault.yml
secrets.yaml

# ==========================================================
# Temporary Files / Cache
# ==========================================================

tmp/
temp/

.cache/

*.tmp
*.bak
*.backup
*.save

# ==========================================================
# Security Lab Runtime Artifacts
# ==========================================================

*.pcap
*.pcapng
*.dump
*.trace

# ==========================================================
# Git Local Overrides
# ==========================================================

.gitconfig
.gitconfig.local
# =====================================================

# Sysadmin Security Lab - Global .gitignore

# =====================================================

# Purpose:

# Ignore OS, IDE, runtime, build artifacts, and secrets

# across multi-language DevSecOps lab environments.

# =====================================================

# =========================

# Operating System Files

# =========================

.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini
*.lnk

# =========================

# Editors / IDEs

# =========================

.vscode/
.idea/
*.swp
*.swo
*~
*.orig

# =========================

# Python

# =========================

**pycache**/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.coverage
htmlcov/

# Virtual environments

venv/
env/
.venv/

# =========================

# Node / JavaScript

# =========================

node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =========================

# Java / Kotlin / Scala

# =========================

*.class
*.jar
*.war
*.ear
*.iml
.gradle/
build/
target/

# =========================

# Go

# =========================

*.exe
*.exe~
*.dll
*.so
*.dylib
vendor/

# =========================

# Rust

# =========================

target/

# Cargo.lock (uncomment for libraries only)

# =========================

# .NET

# =========================

bin/
obj/
*.user
*.suo

# =========================

# Ruby

# =========================

*.gem
.bundle/
vendor/bundle

# =========================

# PHP

# =========================

vendor/

# =========================

# Vagrant / Virtual Labs

# =========================

.vagrant/

# =========================

# Logs / Databases / Runtime Data

# =========================

*.log
*.log.*
*.sqlite
*.db
*.pid
*.seed
*.pid.lock

# =========================

# Secrets / Sensitive Data

# =========================

.env
.env.*
!.env.example

*.key
*.pem
*.secret
*.token

secrets.yaml
credentials.*
vault.yml

# IMPORTANT: never track local overrides or secrets

config.local.json
config.*.local.json

# =========================

# Temporary / Cache Files

# =========================

tmp/
temp/
*.tmp
*.bak
*.save
*.backup
.cache/

# =========================

# Security / Lab Runtime Artifacts

# =========================

*.pcap
*.pcapng
*.dump
*.trace

# =========================

# Git / Local Developer Overrides

# =========================

.gitconfig
.gitconfig.local.*
.gitconfig

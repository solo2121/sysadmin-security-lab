# Auto-detect libvirt network
def detect_libvirt_network
  begin
    output = `sudo virsh net-dumpxml vagrant-libvirt 2>/dev/null`
    if $?.success? && !output.empty?
      doc = REXML::Document.new(output)
      ip_element = REXML::XPath.first(doc, "//ip")
      if ip_element
        network = ip_element.attribute('address').value
        prefix = ip_element.attribute('netmask').value
        prefix_length = prefix ? IPAddr.new(prefix).to_i.to_s(2).count('1') : 24
        return "#{network}/#{prefix_length}"
      end
    end
  rescue => e
    puts "Warning: Could not detect vagrant-libvirt network: #{e}"
  end
  begin
    output = `sudo virsh net-dumpxml default 2>/dev/null`
    if $?.success? && !output.empty?
      doc = REXML::Document.new(output)
      ip_element = REXML::XPath.first(doc, "//ip")
      if ip_element
        network = ip_element.attribute('address').value
        prefix = ip_element.attribute('netmask').value
        prefix_length = prefix ? IPAddr.new(prefix).to_i.to_s(2).count('1') : 24
        return "#{network}/#{prefix_length}"
      end
    end
  rescue => e
    puts "Warning: Could not detect default network: #{e}"
  end
  "192.168.121.0/24"
end

LIBVIRT_NETWORK = detect_libvirt_network
puts "Using libvirt network: #{LIBVIRT_NETWORK}"
network_parts = LIBVIRT_NETWORK.split('/')
NETWORK_BASE = network_parts[0].split('.')[0..2].join('.')
def vm_ip(octet)
  "#{NETWORK_BASE}.#{octet}"
end

MASTER_IP = vm_ip(114)
File.write("/tmp/lab.env", "MASTER_IP=#{MASTER_IP}\nNETWORK_BASE=#{NETWORK_BASE}\n")


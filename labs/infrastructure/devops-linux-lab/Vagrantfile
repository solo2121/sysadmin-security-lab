# -*- mode: ruby -*-
# vi: set ft=ruby :

ENV['LIBVIRT_DEFAULT_URI'] = 'qemu:///system'
Vagrant.require_version ">= 2.2.0"

DEFAULT_CONFIG = {
  memory: 1024,
  cpus: 1,
  disks: []
}.freeze

def configure_libvirt(vm, overrides = {})
  settings = DEFAULT_CONFIG.merge(overrides)

  vm.vm.provider :libvirt do |libvirt|
    libvirt.memory = settings[:memory]
    libvirt.cpus = settings[:cpus]
    libvirt.nested = true
    libvirt.uri = "qemu:///system"
    libvirt.graphics_type = "vnc"
    libvirt.graphics_ip = "127.0.0.1"

    settings[:disks].each do |disk|
      libvirt.storage :file,
        size: disk[:size],
        type: "qcow2",
        bus: "virtio",
        device: disk[:device]
    end
  end
end

Vagrant.configure("2") do |config|

  config.vm.synced_folder ".", "/vagrant", disabled: false

  machines = {
    "devops" => {
      box: "bento/ubuntu-24.04",
      ip: "192.168.56.10",
      memory: 6144,
      cpus: 3,
      disks: [
        { size: "5G", device: "vdb" },
        { size: "5G", device: "vdc" },
        { size: "2G", device: "vdd" }
      ]
    }
  }

  linux_labs = {
    "ubuntu-lab" => { box: "bento/ubuntu-24.04", ip: "192.168.56.20" },
    "rocky-lab"  => { box: "cloud-image/rocky-10", ip: "192.168.56.21" },
    "alma-lab"   => { box: "cloud-image/almalinux-10", ip: "192.168.56.22" },
    "opensuse-lab" => { box: "opensuse/Leap-15.6", ip: "192.168.56.23" }
  }

  ans_nodes = {
    "ans-node1" => "192.168.56.30",
    "ans-node2" => "192.168.56.31"
  }

  all_hosts = machines.merge(linux_labs).merge(ans_nodes.transform_values { |ip| { ip: ip } })

  hosts_entries = all_hosts.map do |name, data|
    "#{data[:ip]} #{name}"
  end.join("\n")

  config.vm.provision "shell", run: "always", inline: <<-SHELL
set -e

LAB_HOSTS_START="# Vagrant DevSecOps Lab START"
LAB_HOSTS_END="# Vagrant DevSecOps Lab END"

if grep -q "$LAB_HOSTS_START" /etc/hosts; then
  sed -i "/$LAB_HOSTS_START/,/$LAB_HOSTS_END/d" /etc/hosts
fi

cat >> /etc/hosts <<EOF

$LAB_HOSTS_START
#{hosts_entries}
$LAB_HOSTS_END

EOF
SHELL

  (machines.merge(linux_labs)).each do |name, opts|

    config.vm.define name do |vm|

      vm.vm.box = opts[:box]
      vm.vm.hostname = name
      vm.vm.network "private_network", ip: opts[:ip]

      configure_libvirt(
        vm,
        memory: opts[:memory] || 1024,
        cpus: opts[:cpus] || 1,
        disks: opts[:disks] || []
      )

      vm.vm.provision "shell", inline: <<-SHELL
#!/usr/bin/env bash
set -euo pipefail

if command -v apt-get >/dev/null 2>&1; then
  apt-get update -qq
  apt-get install -y vim curl wget git jq net-tools python3 python3-pip tmux htop tree ncdu fzf ripgrep

elif command -v dnf >/dev/null 2>&1; then
  dnf install -y vim curl wget git jq net-tools python3 python3-pip podman buildah skopeo

elif command -v zypper >/dev/null 2>&1; then
  zypper install -y vim curl wget git jq net-tools python3 python3-pip
fi
SHELL

      if name == "devops"

        vm.vm.network "forwarded_port", guest: 3000, host: 3000, auto_correct: true
        vm.vm.network "forwarded_port", guest: 9090, host: 9090, auto_correct: true
        vm.vm.network "forwarded_port", guest: 8085, host: 8085, auto_correct: true
        vm.vm.network "forwarded_port", guest: 8086, host: 8086, auto_correct: true
        vm.vm.network "forwarded_port", guest: 8087, host: 8087, auto_correct: true
        vm.vm.network "forwarded_port", guest: 8080, host: 8080, auto_correct: true
        vm.vm.network "forwarded_port", guest: 8443, host: 8443, auto_correct: true

        vm.vm.provision "shell", inline: <<-SHELL
#!/usr/bin/env bash
set -euo pipefail
export DEBIAN_FRONTEND=noninteractive

apt-get update -qq

apt-get install -y ansible git curl wget jq yq python3 python3-pip \
  gnupg software-properties-common net-tools ca-certificates \
  tmux htop tree ncdu fzf ripgrep

# Docker
if ! command -v docker >/dev/null 2>&1; then
  curl -fsSL https://get.docker.com | sh
fi

systemctl enable --now docker
usermod -aG docker vagrant

# kubectl
if ! command -v kubectl >/dev/null 2>&1; then
  curl -LO "https://dl.k8s.io/release/$(curl -Ls https://dl.k8s.io/release/stable.txt)/bin/linux/amd64/kubectl"
  install -m 0755 kubectl /usr/local/bin/kubectl
  rm -f kubectl
fi

# Helm
if ! command -v helm >/dev/null 2>&1; then
  curl -fsSL https://raw.githubusercontent.com/helm/helm/main/scripts/get-helm-3 | bash
fi

# k3d
if ! command -v k3d >/dev/null 2>&1; then
  curl -fsSL https://raw.githubusercontent.com/k3d-io/k3d/main/install.sh | bash
fi

# Terraform
if ! command -v terraform >/dev/null 2>&1; then
  curl -fsSL https://apt.releases.hashicorp.com/gpg | gpg --dearmor -o /usr/share/keyrings/hashicorp.gpg
  echo "deb [signed-by=/usr/share/keyrings/hashicorp.gpg] https://apt.releases.hashicorp.com $(lsb_release -cs) main" \
    > /etc/apt/sources.list.d/hashicorp.list
  apt-get update -qq
  apt-get install -y terraform
fi

pip3 install --break-system-packages checkov semgrep || true

# Trivy
if ! command -v trivy >/dev/null 2>&1; then
  curl -sfL https://raw.githubusercontent.com/aquasecurity/trivy/main/contrib/install.sh | sh -s -- -b /usr/local/bin
fi

# Cosign
if ! command -v cosign >/dev/null 2>&1; then
  curl -LO https://github.com/sigstore/cosign/releases/latest/download/cosign-linux-amd64
  install -m 0755 cosign-linux-amd64 /usr/local/bin/cosign
  rm -f cosign-linux-amd64
fi

# ArgoCD
if ! command -v argocd >/dev/null 2>&1; then
  curl -sSL -o argocd https://github.com/argoproj/argo-cd/releases/latest/download/argocd-linux-amd64
  install -m 0755 argocd /usr/local/bin/argocd
  rm -f argocd
fi

# k3d cluster
if ! k3d cluster list | grep -q devops-cluster; then
  k3d cluster create devops-cluster \
    --api-port 6443 \
    --servers 1 \
    --agents 2 \
    --port "8080:80@loadbalancer" \
    --port "8443:443@loadbalancer" \
    --k3s-arg "--disable=traefik@server:0" \
    --registry-create devops-registry:0.0.0.0:5000
fi

mkdir -p /home/vagrant/.kube
k3d kubeconfig get devops-cluster > /home/vagrant/.kube/config
chown -R vagrant:vagrant /home/vagrant/.kube

# Sysadmin stack
mkdir -p /opt/sysadmin-lab
cd /opt/sysadmin-lab

cat > docker-compose.yml <<'EOF'
services:

  ubuntu:
    image: ubuntu:24.04
    command: sleep infinity

  alpine:
    image: alpine:latest
    command: sleep infinity

  debian:
    image: debian:stable
    command: sleep infinity

  busybox:
    image: busybox:latest
    command: sleep infinity

  netshoot:
    image: nicolaka/netshoot
    command: sleep infinity

  postgres:
    image: postgres:16
    environment:
      POSTGRES_PASSWORD: admin
    ports:
      - "5432:5432"

  mysql:
    image: mysql:8
    environment:
      MYSQL_ROOT_PASSWORD: admin
    ports:
      - "3306:3306"

  redis:
    image: redis:7
    ports:
      - "6379:6379"

  nginx:
    image: nginx:alpine
    ports:
      - "8085:80"

  httpbin:
    image: kennethreitz/httpbin
    ports:
      - "8086:80"

  echo:
    image: hashicorp/http-echo
    command: ["-text=hello sysadmin"]
    ports:
      - "8087:5678"

  prometheus:
    image: prom/prometheus
    ports:
      - "9090:9090"

  grafana:
    image: grafana/grafana
    ports:
      - "3000:3000"
EOF

docker compose up -d

echo "Lab ready"
SHELL
      end
    end
  end

  ans_nodes.each do |name, ip|
    config.vm.define name do |vm|
      vm.vm.box = "bento/ubuntu-24.04"
      vm.vm.hostname = name
      vm.vm.network "private_network", ip: ip

      configure_libvirt(vm, memory: 768, cpus: 1)

      vm.vm.provision "shell", inline: <<-SHELL
apt-get update -qq
apt-get install -y python3 openssh-server
systemctl enable --now ssh
SHELL
    end
  end
end
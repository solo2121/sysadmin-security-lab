# -*- mode: ruby -*-
# vi: set ft=ruby :

ENV['LIBVIRT_DEFAULT_URI'] = 'qemu:///system'
Vagrant.require_version ">= 2.2.0"

DEFAULT_CONFIG = {
  memory: 1024,
  cpus: 1,
  disks: []
}.freeze

def resolve_box(box)
  ENV.fetch("VAGRANT_BOX_#{box.gsub('/', '_').upcase}", box)
end

def configure_libvirt(vm, overrides = {})
  settings = DEFAULT_CONFIG.merge(overrides)

  vm.vm.provider :libvirt do |libvirt|
    libvirt.memory = settings[:memory]
    libvirt.cpus = settings[:cpus]
    libvirt.nested = true
    libvirt.uri = "qemu:///system"
    libvirt.graphics_type = "vnc"
    libvirt.graphics_ip = "127.0.0.1"

    settings[:disks].each do |disk|
      libvirt.storage :file,
        size: disk[:size],
        type: "qcow2",
        bus: "virtio",
        device: disk[:device],
        allow_existing: false
    end
  end
end

Vagrant.configure("2") do |config|

  config.vm.synced_folder ".", "/vagrant", disabled: false

  PORT_BASE = ENV.fetch("PORT_BASE", "10000").to_i

  machines = {
    "devops" => {
      box: "bento/ubuntu-24.04",
      ip: "192.168.56.10",
      memory: 6144,
      cpus: 3,
      disks: [
        { size: "5G", device: "vdb" },
        { size: "5G", device: "vdc" },
        { size: "2G", device: "vdd" }
      ]
    }
  }

  linux_labs = {
    "ubuntu-lab"   => { box: "bento/ubuntu-24.04", ip: "192.168.56.20" },
    "rocky-lab"    => { box: resolve_box("cloud-image/rocky-10"), ip: "192.168.56.21" },
    "alma-lab"     => { box: resolve_box("cloud-image/almalinux-10"), ip: "192.168.56.22" },
    "opensuse-lab" => { box: "opensuse/Leap-15.6", ip: "192.168.56.23" }
  }

  ans_nodes = {
    "ans-node1" => "192.168.56.30",
    "ans-node2" => "192.168.56.31"
  }

  all_hosts = machines.merge(linux_labs).merge(
    ans_nodes.transform_values { |ip| { ip: ip } }
  )

  hosts_entries = all_hosts.map { |n, d| "#{d[:ip]} #{n}" }.join("\n")

  config.vm.provision "shell", run: "always", inline: <<-SHELL
set -e

LAB_HOSTS_START="# Vagrant DevSecOps Lab START"
LAB_HOSTS_END="# Vagrant DevSecOps Lab END"

if grep -q "$LAB_HOSTS_START" /etc/hosts; then
  sed -i "/$LAB_HOSTS_START/,/$LAB_HOSTS_END/d" /etc/hosts
fi

cat >> /etc/hosts <<EOF

$LAB_HOSTS_START
#{hosts_entries}
$LAB_HOSTS_END

EOF
SHELL

  (machines.merge(linux_labs)).each do |name, opts|

    config.vm.define name do |vm|

      vm.vm.box = opts[:box]
      vm.vm.hostname = name
      vm.vm.network "private_network", ip: opts[:ip]

      configure_libvirt(vm,
        memory: opts[:memory] || 1024,
        cpus: opts[:cpus] || 1,
        disks: opts[:disks] || []
      )

      vm.vm.provision "shell", inline: <<-SHELL
#!/usr/bin/env bash
set -euo pipefail

if command -v apt-get >/dev/null 2>&1; then
  apt-get update -qq
  apt-get install -y vim curl wget git jq net-tools python3 python3-pip tmux htop tree ncdu fzf ripgrep
elif command -v dnf >/dev/null 2>&1; then
  dnf install -y vim curl wget git jq net-tools python3 python3-pip podman buildah skopeo
elif command -v zypper >/dev/null 2>&1; then
  zypper install -y vim curl wget git jq net-tools python3 python3-pip
fi
SHELL

      next unless name == "devops"

      vm.vm.network "forwarded_port", guest: 3000, host: PORT_BASE + 3000, auto_correct: true
      vm.vm.network "forwarded_port", guest: 9090, host: PORT_BASE + 9090, auto_correct: true
      vm.vm.network "forwarded_port", guest: 8085, host: PORT_BASE + 8085, auto_correct: true
      vm.vm.network "forwarded_port", guest: 8086, host: PORT_BASE + 8086, auto_correct: true
      vm.vm.network "forwarded_port", guest: 8087, host: PORT_BASE + 8087, auto_correct: true
      vm.vm.network "forwarded_port", guest: 8080, host: PORT_BASE + 8080, auto_correct: true
      vm.vm.network "forwarded_port", guest: 8443, host: PORT_BASE + 8443, auto_correct: true

      vm.vm.provision "shell", inline: <<-SHELL
#!/usr/bin/env bash
set -euo pipefail
export DEBIAN_FRONTEND=noninteractive

apt-get update -qq

apt-get install -y bash-completion ansible git curl wget jq yq python3 python3-pip \
  gnupg software-properties-common net-tools ca-certificates \
  tmux htop tree ncdu fzf ripgrep

# Docker
if ! command -v docker >/dev/null 2>&1; then
  curl -fsSL https://get.docker.com | sh
fi

systemctl enable --now docker

until docker info >/dev/null 2>&1; do
  sleep 3
done

usermod -aG docker vagrant

# kubectl
if ! command -v kubectl >/dev/null 2>&1; then
  curl -fsSL --retry 3 -o kubectl \
    "https://dl.k8s.io/release/$(curl -Ls https://dl.k8s.io/release/stable.txt)/bin/linux/amd64/kubectl"
  install -m 0755 kubectl /usr/local/bin/kubectl
  rm -f kubectl
fi

kubectl completion bash > /etc/bash_completion.d/kubectl || true

grep -qxF '[ -f /etc/bash_completion ] && source /etc/bash_completion' /home/vagrant/.bashrc || \
echo '[ -f /etc/bash_completion ] && source /etc/bash_completion' >> /home/vagrant/.bashrc

grep -qxF 'alias k=kubectl' /home/vagrant/.bashrc || \
echo 'alias k=kubectl' >> /home/vagrant/.bashrc

grep -qxF 'complete -F __start_kubectl k' /home/vagrant/.bashrc || \
echo 'complete -F __start_kubectl k' >> /home/vagrant/.bashrc

chown vagrant:vagrant /home/vagrant/.bashrc

# Helm
command -v helm >/dev/null 2>&1 || \
curl -fsSL https://raw.githubusercontent.com/helm/helm/main/scripts/get-helm-3 | bash

# k3d
command -v k3d >/dev/null 2>&1 || \
curl -fsSL https://raw.githubusercontent.com/k3d-io/k3d/main/install.sh | bash

# Terraform
if ! command -v terraform >/dev/null 2>&1; then
  curl -fsSL https://apt.releases.hashicorp.com/gpg | gpg --dearmor -o /usr/share/keyrings/hashicorp.gpg
  echo "deb [signed-by=/usr/share/keyrings/hashicorp.gpg] https://apt.releases.hashicorp.com $(lsb_release -cs) main" \
    > /etc/apt/sources.list.d/hashicorp.list
  apt-get update -qq
  apt-get install -y terraform
fi

# ArgoCD CLI
if ! command -v argocd >/dev/null 2>&1; then
  curl -sSL -o argocd \
    https://github.com/argoproj/argo-cd/releases/latest/download/argocd-linux-amd64
  install -m 0755 argocd /usr/local/bin/argocd
  rm -f argocd
fi

# k3d
if ! k3d cluster list | grep -q devops-cluster; then
  k3d cluster create devops-cluster \
    --api-port 6443 \
    --servers 1 \
    --agents 2 \
    --port "#{PORT_BASE + 8080}:80@loadbalancer" \
    --port "#{PORT_BASE + 8443}:443@loadbalancer" \
    --k3s-arg "--disable=traefik@server:0" \
    --registry-create devops-registry:0.0.0.0:5000
fi

mkdir -p /home/vagrant/.kube
k3d kubeconfig get devops-cluster > /home/vagrant/.kube/config
chown -R vagrant:vagrant /home/vagrant/.kube

# GitOps
kubectl create namespace argocd || true

kubectl apply -n argocd \
  -f https://raw.githubusercontent.com/argoproj/argo-cd/stable/manifests/install.yaml

kubectl rollout status deployment/argocd-server -n argocd --timeout=180s || true

nohup kubectl port-forward svc/argocd-server -n argocd 9080:443 >/dev/null 2>&1 &

kubectl -n argocd get secret argocd-initial-admin-secret \
  -o jsonpath="{.data.password}" | base64 -d > /opt/argocd-pass.txt || true

echo "GitOps ready"
SHELL
    end
  end

  ans_nodes.each do |name, ip|
    config.vm.define name do |vm|
      vm.vm.box = "bento/ubuntu-24.04"
      vm.vm.hostname = name
      vm.vm.network "private_network", ip: ip

      configure_libvirt(vm, memory: 768, cpus: 1)

      vm.vm.provision "shell", inline: <<-SHELL
#!/usr/bin/env bash
set -e
apt-get update -qq
apt-get install -y python3 openssh-server
systemctl enable --now ssh
SHELL
    end
  end
end
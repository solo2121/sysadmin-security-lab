# -*- mode: ruby -*-
# vi: set ft=ruby :

require 'ipaddr'

ENV['LIBVIRT_DEFAULT_URI'] = 'qemu:///system'
Vagrant.require_version ">= 2.2.0"

DEFAULT = { memory: 1024, cpus: 1 }.freeze

def libvirt(vm, opts = {})
  c = DEFAULT.merge(opts)
  vm.vm.provider :libvirt do |l|
    l.memory = c[:memory]
    l.cpus = c[:cpus]
    l.nested = true
    l.graphics_type = "vnc"
    l.graphics_ip = "127.0.0.1"
  end
end

def attach_lab_disks(vm)
  vm.vm.provider :libvirt do |l|
    l.storage :file, size: "5G", type: "qcow2"
    l.storage :file, size: "5G", type: "qcow2"
    l.storage :file, size: "2G", type: "qcow2"
  end
end

Vagrant.configure("2") do |config|
  config.vm.box_check_update = false
  config.vm.synced_folder ".", "/vagrant", disabled: false

  cluster = {
    "devops-1" => { box: "bento/ubuntu-24.04", ip: "192.168.56.10", memory: 6144, cpus: 4 },
    "worker-1" => { box: "bento/ubuntu-24.04", ip: "192.168.56.11", memory: 3072, cpus: 2 },
    "worker-2" => { box: "bento/ubuntu-24.04", ip: "192.168.56.12", memory: 3072, cpus: 2 }
  }

  linux_labs = {
    "ubuntu-lab" => { box: "bento/ubuntu-24.04", ip: "192.168.56.20" },
    "rocky-lab" => { box: "rockylinux/10", ip: "192.168.56.21" },
    "alma-lab" => { box: "almalinux/10", ip: "192.168.56.22" },
    "suse-lab" => { box: "opensuse/Leap-15.6", ip: "192.168.56.23" }
  }

  ansible_nodes = {
    "node1" => "192.168.56.30",
    "node2" => "192.168.56.31"
  }

  all_hosts = cluster.merge(linux_labs).merge(ansible_nodes.transform_values { |ip| { ip: ip } })
  hosts_entries = all_hosts.map { |n, d| "#{d[:ip]} #{n}" }.join("\n")

  config.vm.provision "shell", run: "always", inline: <<-SHELL
    set -e
    START="# LAB START"
    END="# LAB END"
    sed -i "/$START/,/$END/d" /etc/hosts || true
    cat >> /etc/hosts <<EOF
$START
#{hosts_entries}
$END
EOF
  SHELL

  (cluster.merge(linux_labs)).each do |name, cfg|
    config.vm.define name do |vm|
      vm.vm.box = cfg[:box]
      vm.vm.hostname = name
      vm.vm.network "private_network", ip: cfg[:ip]

      libvirt(vm, memory: cfg[:memory] || 1024, cpus: cfg[:cpus] || 1)
      attach_lab_disks(vm) if linux_labs.key?(name)

      # ================= BASE =================
      vm.vm.provision "shell", inline: <<-'SHELL'
set -euo pipefail
export DEBIAN_FRONTEND=noninteractive

apt-get update -qq || true
apt-get install -y curl wget git jq vim tree tmux htop net-tools \
bash-completion python3 python3-pip netcat-openbsd || true

systemctl enable --now ssh 2>/dev/null || systemctl enable --now sshd 2>/dev/null || true
SHELL

      # ================= DEVOPS MASTER =================
      if name == "devops-1"

        vm.vm.network "forwarded_port", guest: 6443, host: 6443
        vm.vm.network "forwarded_port", guest: 80, host: 8080
        vm.vm.network "forwarded_port", guest: 443, host: 8443
        vm.vm.network "forwarded_port", guest: 5000, host: 5000

        vm.vm.provision "shell", inline: <<-'SHELL'
set -euo pipefail

MASTER_IP=192.168.56.10

# ================= DOCKER (FIXED ALWAYS) =================
if ! command -v docker >/dev/null 2>&1; then
  curl -fsSL https://get.docker.com | sh
fi

systemctl enable --now docker
usermod -aG docker vagrant || true

# ================= DOCKER COMPOSE INSTALLATION =================
# Install docker-compose plugin (modern approach)
if ! docker compose version >/dev/null 2>&1; then
  apt-get update -qq || true
  apt-get install -y docker-compose-plugin || true
fi

# Fallback: Install standalone docker-compose if plugin not available
if ! docker compose version >/dev/null 2>&1 && ! command -v docker-compose >/dev/null 2>&1; then
  curl -fsSL "https://github.com/docker/compose/releases/download/v2.24.0/docker-compose-$(uname -s)-$(uname -m)" -o /usr/local/bin/docker-compose
  chmod +x /usr/local/bin/docker-compose
fi

cat > /etc/docker/daemon.json <<EOF
{
  "insecure-registries": ["192.168.56.10"],
  "storage-driver": "overlay2",
  "log-driver": "json-file",
  "log-opts": {
    "max-size": "10m",
    "max-file": "3"
  }
}
EOF
systemctl restart docker

# ================= K3S INSTALL =================
curl -sfL https://get.k3s.io | INSTALL_K3S_EXEC="server \
  --write-kubeconfig-mode 644 \
  --node-ip ${MASTER_IP} \
  --advertise-address ${MASTER_IP}" sh -

systemctl enable --now k3s

export KUBECONFIG=/etc/rancher/k3s/k3s.yaml
export PATH=$PATH:/usr/local/bin:/var/lib/rancher/k3s/bin

# ================= kubectl FIX =================
if [ -f /usr/local/bin/kubectl ]; then
  kubectl completion bash > /etc/bash_completion.d/kubectl || true
  echo 'source <(kubectl completion bash)' >> /root/.bashrc
  echo 'source <(kubectl completion bash)' >> /home/vagrant/.bashrc
fi

# ================= HELM =================
if ! command -v helm >/dev/null 2>&1; then
  curl -fsSL https://raw.githubusercontent.com/helm/helm/main/scripts/get-helm-3 | bash
fi

# ================= OFFLINE IMAGES =================
AIRGAP_IMAGES=(
  rancher/mirrored-pause:3.6
  rancher/mirrored-coredns-coredns:1.10.1
  rancher/local-path-provisioner:v0.0.24
  registry.k8s.io/ingress-nginx/controller:v1.11.0
  registry.k8s.io/metrics-server/metrics-server:v0.6.3
  aquasec/trivy:latest
  falcosecurity/falco:0.38.2
  quay.io/argoproj/argocd:v2.11.3
  prom/prometheus:v2.54.1
  grafana/grafana:11.1.0
  postgres:16
  redis:7
  nginx:alpine
  busybox:latest
  alpine:latest
  goharbor/harbor-core:v2.10.0
  goharbor/harbor-db:v2.10.0
  goharbor/harbor-jobservice:v2.10.0
  goharbor/harbor-log:v2.10.0
  goharbor/harbor-portal:v2.10.0
  goharbor/harbor-registryctl:v2.10.0
  goharbor/registry-photon:v2.10.0
)

for img in "${AIRGAP_IMAGES[@]}"; do
  docker pull "$img" || true
done

echo "OFFLINE IMAGES READY"

# ================= HARBOR SETUP =================
mkdir -p /opt/harbor
cd /opt/harbor

# Download Harbor (using offline installer to avoid online dependencies)
if [ ! -f /opt/harbor/docker-compose.yml ]; then
  # Create minimal harbor docker-compose (self-contained)
  cat > /opt/harbor/docker-compose.yml <<'DOCKER_COMPOSE'
version: '3.8'
services:
  harbor-db:
    image: goharbor/harbor-db:v2.10.0
    container_name: harbor-db
    environment:
      POSTGRES_PASSWORD: harbor12345
    volumes:
      - harbor-db-data:/var/lib/postgresql/data
    networks:
      - harbor

  harbor-core:
    image: goharbor/harbor-core:v2.10.0
    container_name: harbor-core
    environment:
      DATABASE_TYPE: postgresql
      POSTGRES_HOST: harbor-db
      POSTGRES_PORT: 5432
      POSTGRES_USERNAME: postgres
      POSTGRES_PASSWORD: harbor12345
      POSTGRES_DBNAME: registry
      HARBOR_ADMIN_PASSWORD: Harbor12345
      REGISTRY_CONTROLLER_URL: http://harbor-registryctl:8080
      LOG_LEVEL: info
    ports:
      - "80:8080"
      - "443:8443"
    depends_on:
      - harbor-db
      - harbor-registryctl
    volumes:
      - harbor-data:/data
    networks:
      - harbor

  harbor-registryctl:
    image: goharbor/harbor-registryctl:v2.10.0
    container_name: harbor-registryctl
    environment:
      REGISTRY_STORAGE_FILESYSTEM_ROOTDIRECTORY: /storage
      REGISTRY_HTTP_SECRET: secret
    volumes:
      - harbor-storage:/storage
    networks:
      - harbor

  harbor-registry:
    image: goharbor/registry-photon:v2.10.0
    container_name: harbor-registry
    volumes:
      - harbor-storage:/storage
    networks:
      - harbor

  harbor-log:
    image: goharbor/harbor-log:v2.10.0
    container_name: harbor-log
    volumes:
      - harbor-logs:/var/log/docker
    networks:
      - harbor

  harbor-portal:
    image: goharbor/harbor-portal:v2.10.0
    container_name: harbor-portal
    environment:
      HARBOR_TITLE: "Enterprise Harbor Registry"
    networks:
      - harbor

volumes:
  harbor-db-data:
  harbor-data:
  harbor-storage:
  harbor-logs:

networks:
  harbor:
    driver: bridge
DOCKER_COMPOSE

  # Start Harbor using docker compose (plugin) or docker-compose (standalone)
  if docker compose version >/dev/null 2>&1; then
    docker compose up -d
  else
    docker-compose up -d
  fi
  
  # Wait for harbor to be ready
  sleep 30
  
  # Test Harbor API
  curl -s http://localhost/api/v2.0/systeminfo || true
fi

echo "HARBOR READY - Access at http://192.168.56.10 or http://192.168.56.10:80"
echo "Default credentials: admin / Harbor12345"

# ================= TOKEN =================
cp /var/lib/rancher/k3s/server/token /vagrant/k3s-token || true
chmod 644 /vagrant/k3s-token || true

echo "MASTER READY"
SHELL

      # ================= WORKERS =================
      elsif name.start_with?("worker")
        vm.vm.provision "shell", inline: <<-'SHELL'
set -euo pipefail

MASTER=192.168.56.10

until nc -z $MASTER 6443; do sleep 3; done
until [ -f /vagrant/k3s-token ]; do sleep 3; done

TOKEN=$(cat /vagrant/k3s-token)

curl -sfL https://get.k3s.io | \
K3S_URL="https://${MASTER}:6443" \
K3S_TOKEN="${TOKEN}" sh -

echo "WORKER READY"
SHELL
      end
    end
  end
end

def should_start?(vm_name, profile, start_list)
  return true if start_list.include?(vm_name)
  case profile
  when 'minimal'
    vm_name == 'devops-1' || vm_name == 'worker-1'
  when 'dev'
    vm_name == 'devops-1' || vm_name == 'worker-1' ||
    vm_name == 'node1' || vm_name == 'node2'
  when 'full'
    true
  else
    vm_name == 'devops-1' || vm_name == 'worker-1'
  end
end

DEFAULT = { memory: 1024, cpus: 1 }.freeze
def libvirt(vm, opts = {})
  c = DEFAULT.merge(opts)
  vm.vm.provider :libvirt do |l|
    l.memory = c[:memory]
    l.cpus = c[:cpus]
    l.nested = true
    l.graphics_type = "vnc"
    l.graphics_ip = "127.0.0.1"
    l.video_type = "virtio"
    l.cpu_mode = "host-passthrough"
  end
end

def attach_lab_disks(vm)
  vm.vm.provider :libvirt do |l|
    l.storage :file, size: "5G", type: "qcow2", cache: "writeback"
    l.storage :file, size: "5G", type: "qcow2", cache: "writeback"
    l.storage :file, size: "2G", type: "qcow2", cache: "writeback"
  end
end

Vagrant.configure("2") do |config|
  config.vm.box_check_update = false
  config.vm.synced_folder ".", "/vagrant", disabled: false
  config.ssh.connect_timeout = 600
  config.vm.boot_timeout = 1200

  config.vm.provision "shell", inline: <<-SHELL
    cat > /vagrant/lab.env << 'EOF'
MASTER_IP=#{MASTER_IP}
NETWORK_BASE=#{NETWORK_BASE}
OPENTOFU_VERSION=#{OPENTOFU_VERSION}
KIND_VERSION=#{KIND_VERSION}
K3D_VERSION=#{K3D_VERSION}
KUBECTL_VERSION=#{KUBECTL_VERSION}
HARBOR_PASS=#{HARBOR_PASS}
EOF
  SHELL

  cluster = {
    "devops-1" => { box: "bento/ubuntu-24.04", ip: MASTER_IP, memory: 8192, cpus: 4, role: "master" },
    "worker-1" => { box: "bento/ubuntu-24.04", ip: vm_ip(11), memory: 2048, cpus: 2, role: "worker" },
    "worker-2" => { box: "bento/ubuntu-24.04", ip: vm_ip(12), memory: 2048, cpus: 2, role: "worker" }
  }

  linux_labs = {
    "ubuntu-lab" => { box: "bento/ubuntu-24.04", ip: vm_ip(20), memory: 1024, cpus: 1, role: "lab" },
    "rocky-lab" => { box: "rockylinux/10", ip: vm_ip(21), memory: 1024, cpus: 1, role: "lab" },
    "alma-lab" => { box: "almalinux/10", ip: vm_ip(22), memory: 1024, cpus: 1, role: "lab" },
    "suse-lab" => { box: "opensuse/Leap-15.6", ip: vm_ip(23), memory: 1024, cpus: 1, role: "lab" }
  }

  ansible_nodes = {
    "node1" => { box: "bento/ubuntu-24.04", ip: vm_ip(30), memory: 1024, cpus: 1, role: "ansible" },
    "node2" => { box: "bento/ubuntu-24.04", ip: vm_ip(31), memory: 1024, cpus: 1, role: "ansible" }
  }

  # Modern Learning VMs
  kind_labs = {
    "kind-lab" => {
      box: "bento/ubuntu-24.04",
      ip: vm_ip(40),
      memory: 4096,
      cpus: 2,
      role: "kind"
    }
  }

  k3d_labs = {
    "k3d-lab" => {
      box: "bento/ubuntu-24.04",
      ip: vm_ip(41),
      memory: 4096,
      cpus: 2,
      role: "k3d"
    }
  }

  # Merge all VMs
  all_vms = cluster.merge(linux_labs).merge(ansible_nodes).merge(kind_labs).merge(k3d_labs)
  vms_to_start = all_vms.select { |name, _| should_start?(name, LAB_PROFILE, START_VMS) }
  hosts_entries = all_vms.map { |n, c| "#{c[:ip]} #{n}" }.join("\n")

  vms_to_start.each do |name, cfg|
    config.vm.define name do |vm|
      vm.vm.box = cfg[:box]
      vm.vm.hostname = name
      vm.vm.network "private_network", ip: cfg[:ip]
      libvirt(vm, memory: cfg[:memory] || 1024, cpus: cfg[:cpus] || 1)
      attach_lab_disks(vm) if linux_labs.key?(name)

      vm.vm.provision "shell", run: "always", inline: <<-SHELL
        set -e
        START="# LAB START"
        END="# LAB END"
        sed -i "/$START/,/$END/d" /etc/hosts 2>/dev/null || true
        cat >> /etc/hosts <<EOF
$START
#{hosts_entries}
$END
EOF
      SHELL

      vm.vm.provision "shell", inline: <<-'SHELL'
        set -euo pipefail
        [ -f /var/lib/.base_provisioned ] && { echo "Base already done, skipping"; exit 0; }
        export DEBIAN_FRONTEND=noninteractive
        if command -v apt-get >/dev/null 2>&1; then
          apt-get update -qq
          apt-get install -y curl wget git jq vim tree tmux htop net-tools \
            bash-completion python3 python3-pip netcat-openbsd openssl
          systemctl enable --now ssh 2>/dev/null || systemctl enable --now sshd 2>/dev/null || true
        elif command -v dnf >/dev/null 2>&1; then
          dnf install -y curl wget git jq vim tree tmux htop net-tools \
            bash-completion python3 python3-pip nmap-ncat openssl
          systemctl enable --now sshd 2>/dev/null || true
        elif command -v zypper >/dev/null 2>&1; then
          zypper install -y curl wget git jq vim tree tmux htop net-tools \
            bash-completion python3 python3-pip netcat openssl
          systemctl enable --now sshd 2>/dev/null || true
        fi
        touch /var/lib/.base_provisioned
      SHELL

      case cfg[:role]
      when "master"
        # ============================================================
        # PORT FORWARDING - Enterprise UI Access
        # ============================================================
        vm.vm.network "forwarded_port", guest: 80, host: 8080, host_ip: "127.0.0.1"
        vm.vm.network "forwarded_port", guest: 443, host: 8443, host_ip: "127.0.0.1"
        vm.vm.network "forwarded_port", guest: 6443, host: K8S_API_HOST_PORT.to_i, host_ip: "127.0.0.1"
        vm.vm.network "forwarded_port", guest: 30001, host: 30001, host_ip: "127.0.0.1"
        # Argo CD UI
        vm.vm.network "forwarded_port", guest: 30003, host: 30003, host_ip: "127.0.0.1"
        vm.vm.network "forwarded_port", guest: 30004, host: 30004, host_ip: "127.0.0.1"

        vm.vm.provision "shell", inline: <<-SHELL
          if [ "${DEBUG:-false}" = "true" ]; then set -x; fi
          set -euo pipefail

          MASTER_IP="#{cfg[:ip]}"
          HARBOR_PROJECT="#{HARBOR_PROJECT}"
          HARBOR_CHART_VERSION="#{HARBOR_CHART_VERSION}"
          INGRESS_NGINX_VERSION="#{INGRESS_NGINX_VERSION}"
          K3S_VERSION="#{K3S_VERSION}"
          DOCKER_VERSION="#{DOCKER_VERSION}"
          HARBOR_PASS="#{HARBOR_PASS}"
          TOKEN_PATH=/vagrant/.k3s_token
          CLUSTER_READY=/vagrant/.cluster_ready
          FAST_BOOT="#{FAST_BOOT}"
          LAB_PROFILE="#{LAB_PROFILE}"
          K8S_API_HOST_PORT="#{K8S_API_HOST_PORT}"
          CACHE_MODE="#{CACHE_MODE}"
          AIRGAP_IMAGES=(
#{AIRGAP_IMAGES.map { |image| "\"#{image}\"" }.join("\n")}
          )

          export PATH=$PATH:/usr/local/bin:/var/lib/rancher/k3s/bin
          export KUBECONFIG=/etc/rancher/k3s/k3s.yaml

          STATE_DIR="/var/lib/lab_state"
          mkdir -p "$STATE_DIR"
          transition_state() {
            local new_state="$1"
            echo "$new_state" > "$STATE_DIR/current_state"
            echo "$(date -Iseconds): $new_state" >> "$STATE_DIR/state_history"
          }
          transition_state "starting"

          get_iface() {
            local ip="$1"
            iface=$(ip route show default 2>/dev/null | awk '/default/ {print $5; exit}')
            if [ -z "$iface" ]; then
              iface=$(ip route get "$ip" 2>/dev/null | awk '/dev/ {for(i=1;i<=NF;i++) if($i=="dev") print $(i+1)}' | head -n1)
            fi
            if [ -z "$iface" ]; then
              iface=$(ip -o link show | awk -F': ' '$2 ~ /^(ens|enp|eth)/ {print $2; exit}')
            fi
            [ -z "$iface" ] && iface="eth0"
            echo "$iface"
          }

          wait_for() {
            local check_func="$1"
            local message="$2"
            local max_attempts="${3:-60}"
            local attempt=0
            while ! $check_func 2>/dev/null; do
              attempt=$((attempt + 1))
              if [ "$attempt" -ge "$max_attempts" ]; then
                echo "ERROR: Timeout waiting for: $message"
                return 1
              fi
              echo " Waiting for $message... ($attempt/$max_attempts)"
              sleep 5
            done
            echo "Ready: $message"
          }

          check_k3s_service() { systemctl is-active --quiet k3s; }
          check_api_ready() { curl -sk https://127.0.0.1:6443/readyz >/dev/null 2>&1; }
          check_kubectl_ready() { kubectl --kubeconfig /etc/rancher/k3s/k3s.yaml get nodes >/dev/null 2>&1; }

          check_node_registered() {
            kubectl --kubeconfig /etc/rancher/k3s/k3s.yaml get node devops-1 -o jsonpath='{.status.conditions[?(@.type=="Ready")].status}' 2>/dev/null | grep -qx "True"
          }

          echo "Waiting for network to fully stabilize..."
          for i in $(seq 1 60); do
            if ip route get 8.8.8.8 >/dev/null 2>&1; then
              echo "Network routing is ready"
              break
            fi
            echo "Waiting for routing table... ($i/60)"
            sleep 3
          done

          echo "Configuring kernel modules for Kubernetes..."
          modprobe br_netfilter || true
          modprobe overlay || true
          modprobe vxlan || true
          cat <<EOF >/etc/modules-load.d/k8s.conf
overlay
br_netfilter
vxlan
EOF
          echo br_netfilter | tee /etc/modules-load.d/br_netfilter.conf >/dev/null
          cat <<EOF >/etc/sysctl.d/99-kubernetes.conf
net.bridge.bridge-nf-call-iptables=1
net.bridge.bridge-nf-call-ip6tables=1
net.ipv4.ip_forward=1
net.ipv4.conf.all.rp_filter=0
net.ipv4.conf.default.rp_filter=0
EOF
          sysctl --system

          echo "Configuring iptables for K3s compatibility..."
          apt-get install -y iptables arptables ebtables 2>/dev/null || true
          update-alternatives --set iptables /usr/sbin/iptables-legacy 2>/dev/null || true
          update-alternatives --set ip6tables /usr/sbin/ip6tables-legacy 2>/dev/null || true

          echo "Disabling swap..."
          swapoff -a || true
          sed -i '/ swap / s/^/#/' /etc/fstab 2>/dev/null || true

          RESTART_DOCKER=0
          if ! systemctl is-active --quiet docker 2>/dev/null; then
            if ! command -v docker >/dev/null 2>&1; then
              export DEBIAN_FRONTEND=noninteractive
              apt-get update -qq
              apt-get install -y ca-certificates curl gnupg lsb-release
              install -m 0755 -d /etc/apt/keyrings
              curl -fsSL https://download.docker.com/linux/ubuntu/gpg | gpg --dearmor -o /etc/apt/keyrings/docker.gpg
              chmod a+r /etc/apt/keyrings/docker.gpg
              echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.gpg] https://download.docker.com/linux/ubuntu $(lsb_release -cs) stable" > /etc/apt/sources.list.d/docker.list
              apt-get update -qq

              DOCKER_INSTALL_METHOD=""
              DOCKER_ACTUAL_VERSION=""
              UBUNTU_VERSION_ID="$(. /etc/os-release && echo "$VERSION_ID")"
              UBUNTU_CODENAME="$(lsb_release -cs)"
              VERSION_STRING_CODENAME="5:${DOCKER_VERSION}-1~ubuntu.${UBUNTU_VERSION_ID}~${UBUNTU_CODENAME}"
              VERSION_STRING_BROAD="${DOCKER_VERSION}*"

              if apt-cache madison docker-ce 2>/dev/null | grep -q "$VERSION_STRING_CODENAME"; then
                apt-get install -y docker-ce="$VERSION_STRING_CODENAME" docker-ce-cli="$VERSION_STRING_CODENAME" containerd.io docker-buildx-plugin docker-compose-plugin
                DOCKER_INSTALL_METHOD="exact"
              elif apt-cache madison docker-ce 2>/dev/null | grep -q "${DOCKER_VERSION}"; then
                MATCHED_VERSION=$(apt-cache madison docker-ce 2>/dev/null | grep "${DOCKER_VERSION}" | head -1 | awk '{print $3}')
                apt-get install -y docker-ce="$MATCHED_VERSION" docker-ce-cli="$MATCHED_VERSION" containerd.io docker-buildx-plugin docker-compose-plugin
                DOCKER_INSTALL_METHOD="madison_match"
              else
                echo "WARNING: Exact Docker version not found - installing latest"
                apt-get install -y docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin
                DOCKER_INSTALL_METHOD="latest_fallback"
              fi
              DOCKER_ACTUAL_VERSION="$(docker --version | cut -d' ' -f3 | tr -d ',')"

              cat > /var/lib/docker_installation_record <<EOF
DESIRED_VERSION=${DOCKER_VERSION}
ACTUAL_VERSION=${DOCKER_ACTUAL_VERSION}
INSTALL_METHOD=${DOCKER_INSTALL_METHOD}
INSTALLED_AT=$(date -Iseconds)
EOF
              if [ "${DOCKER_VERSION}" != "${DOCKER_ACTUAL_VERSION}" ] && [ "${FAST_BOOT}" != "true" ]; then
                echo "WARNING: Docker version drift detected. Continuing anyway."
              fi
            fi
            systemctl enable --now docker
            usermod -aG docker vagrant || true
            RESTART_DOCKER=1
          fi

          if [ ! -f /etc/docker/daemon.json ] || [ "$RESTART_DOCKER" -eq 1 ]; then
            cat > /etc/docker/daemon.json <<EOF
{
  "storage-driver": "overlay2",
  "log-driver": "json-file",
  "log-opts": {"max-size": "10m", "max-file": "3"},
  "insecure-registries": ["${MASTER_IP}:30001"]
}
EOF
            RESTART_DOCKER=1
          fi
          [ "$RESTART_DOCKER" -eq 1 ] && systemctl restart docker || true
          transition_state "docker_installed"

          if ! command -v k3s >/dev/null 2>&1; then
            echo "Installing K3s ${K3S_VERSION}..."
            IFACE=$(get_iface "${MASTER_IP}")
            echo "Detected interface (for reference): ${IFACE}"

            K3S_INSTALLED=0
            for attempt in 1 2 3
            do
              echo "K3s install attempt $attempt/3"
              if curl -sfL https://get.k3s.io | INSTALL_K3S_VERSION="${K3S_VERSION}" \
                INSTALL_K3S_EXEC="server \
                  --write-kubeconfig-mode 644 \
                  --node-name devops-1 \
                  --node-ip ${MASTER_IP} \
                  --advertise-address ${MASTER_IP} \
                  --tls-san ${MASTER_IP},127.0.0.1 \
                  --node-external-ip ${MASTER_IP} \
                  --flannel-backend=vxlan \
                  --cluster-cidr=10.42.0.0/16 \
                  --service-cidr=10.43.0.0/16 \
                  --disable traefik \
                  --disable-network-policy" sh -; then
                K3S_INSTALLED=1
                break
              fi
              echo "K3s attempt $attempt failed, retrying in 15s..."
              sleep 15
            done
            [ "$K3S_INSTALLED" -eq 0 ] && { echo "ERROR: K3s install failed after 3 attempts"; exit 1; }
            sleep 15
          fi

          systemctl enable k3s || true
          systemctl start k3s || true
          transition_state "k3s_installed"

          echo "Allowing flannel to stabilize..."
          sleep 40
          wait_for check_k3s_service "k3s service" 120
          wait_for check_api_ready "API /readyz" 180

          echo "Waiting for node devops-1 to register and become Ready..."
          for i in $(seq 1 300); do
            echo "Node registration check $i/300"
            kubectl --kubeconfig /etc/rancher/k3s/k3s.yaml get nodes -o wide 2>/dev/null || true
            journalctl -u k3s --no-pager | tail -40
            if check_node_registered; then
              echo "Node devops-1 is Ready!"
              break
            fi
            sleep 6
          done
          wait_for check_node_registered "node devops-1 Ready" 300 || echo "WARNING: Continuing despite delay"

          transition_state "node_registered"
          transition_state "node_ready"
          transition_state "cluster_ready"

          mkdir -p /vagrant
          if [ ! -f "$TOKEN_PATH" ]; then
            cp /var/lib/rancher/k3s/server/node-token "$TOKEN_PATH"
            chmod 644 "$TOKEN_PATH"
          fi
          touch "$CLUSTER_READY"

          cat > /vagrant/.cluster_state.json.tmp <<EOF
{
  "cluster_ready": true,
  "master_ip": "${MASTER_IP}"
}
EOF
          mv /vagrant/.cluster_state.json.tmp /vagrant/.cluster_state.json

          wait_for check_kubectl_ready "kubectl API ready" 120
          [ -f /usr/local/bin/kubectl ] || ln -sf /var/lib/rancher/k3s/bin/kubectl /usr/local/bin/kubectl

          mkdir -p /etc/bash_completion.d
          kubectl --kubeconfig /etc/rancher/k3s/k3s.yaml completion bash > /etc/bash_completion.d/kubectl 2>/dev/null
          grep -q "source /etc/bash_completion.d/kubectl" /home/vagrant/.bashrc 2>/dev/null || echo 'source /etc/bash_completion.d/kubectl' >> /home/vagrant/.bashrc
          grep -q "alias k=" /home/vagrant/.bashrc 2>/dev/null || echo "alias k='kubectl'" >> /home/vagrant/.bashrc

          command -v helm >/dev/null 2>&1 || curl -fsSL https://raw.githubusercontent.com/helm/helm/main/scripts/get-helm-3 | bash

          if [ "${FAST_BOOT}" != "true" ]; then
            echo "Installing Ingress NGINX ${INGRESS_NGINX_VERSION}..."
            kubectl apply -f "https://raw.githubusercontent.com/kubernetes/ingress-nginx/controller-${INGRESS_NGINX_VERSION}/deploy/static/provider/cloud/deploy.yaml"
            kubectl wait --namespace ingress-nginx --for=condition=Ready pod --selector=app.kubernetes.io/component=controller --timeout=180s 2>/dev/null || true
            check_ingress_running() { kubectl get pods -n ingress-nginx --no-headers 2>/dev/null | grep -q Running; }
            wait_for check_ingress_running "Ingress NGINX" 180
            transition_state "ingress_installed"
          fi

          if [ "${FAST_BOOT}" != "true" ]; then
            echo "Installing Harbor ${HARBOR_CHART_VERSION}..."
            helm repo list 2>/dev/null | awk '{print $1}' | grep -qx "harbor" || helm repo add harbor https://helm.goharbor.io
            for i in 1 2 3; do
              if helm repo update 2>/dev/null; then break; fi
              sleep 5
            done
            if helm search repo harbor/harbor --versions 2>/dev/null | grep -q "${HARBOR_CHART_VERSION}"; then
              HELM_VERSION_FLAG="--version ${HARBOR_CHART_VERSION}"
            else
              HELM_VERSION_FLAG=""
            fi

            helm uninstall harbor -n harbor 2>/dev/null || true
            kubectl delete namespace harbor --ignore-not-found=true
            sleep 5

            kubectl create namespace harbor --dry-run=client -o yaml | kubectl apply -f -
            mkdir -p /opt/harbor
            cd /opt/harbor
            if [ ! -f harbor.key ]; then
              openssl req -x509 -nodes -days 365 -newkey rsa:2048 -keyout harbor.key -out harbor.crt -subj "/CN=${MASTER_IP}" -addext "subjectAltName = IP:${MASTER_IP},IP:127.0.0.1"
            fi
            kubectl create secret tls harbor-tls --cert=harbor.crt --key=harbor.key -n harbor --dry-run=client -o yaml | kubectl apply -f -

            cat > /opt/harbor-values.yaml <<EOF
expose:
  type: nodePort
  tls:
    enabled: true
    certSource: auto
    auto:
      commonName: ${MASTER_IP}
  nodePort:
    ports:
      https:
        nodePort: 30001
externalURL: https://${MASTER_IP}:30001
harborAdminPassword: ${HARBOR_PASS}
persistence:
  enabled: true
  persistentVolumeClaim:
    registry:
      size: 5Gi
trivy:
  enabled: true
EOF

            helm upgrade --install harbor harbor/harbor ${HELM_VERSION_FLAG} -n harbor -f /opt/harbor-values.yaml --wait --timeout 15m || {
              echo "ERROR: Harbor install failed — rolling back"
              kubectl get pods -n harbor || true
              helm uninstall harbor -n harbor 2>/dev/null || true
              exit 1
            }

            echo "Waiting for Harbor API to be healthy..."
            HARBOR_HEALTHY=false
            for i in $(seq 1 120); do
              if curl -sk --max-time 10 "https://${MASTER_IP}:30001/api/v2.0/health" 2>/dev/null | grep -q '"status":"healthy"'; then
                echo "Harbor API is healthy"
                HARBOR_HEALTHY=true
                break
              fi
              echo " Waiting for Harbor API... ($i/120)"
              sleep 10
            done
            if [ "$HARBOR_HEALTHY" = "false" ]; then
              echo "ERROR: Harbor API failed to become healthy after 120 attempts"
              exit 1
            fi

            # ============================================================
            # FIX: Reconfigure Docker daemon to trust Harbor registry
            # This MUST happen BEFORE image seeding starts
            # ============================================================
            echo "Reconfiguring Docker daemon to trust Harbor registry..."
            cat > /etc/docker/daemon.json <<EOF
{
  "storage-driver": "overlay2",
  "log-driver": "json-file",
  "log-opts": {"max-size": "10m", "max-file": "3"},
  "insecure-registries": ["${MASTER_IP}:30001"]
}
EOF
            systemctl restart docker
            sleep 10
            echo "Docker daemon reconfigured with Harbor registry"

            echo "=========================================="
            echo "Seeding ${HARBOR_PROJECT} project with airgap images"
            echo "=========================================="

            for i in $(seq 1 30); do
              if curl -sk --max-time 5 "https://${MASTER_IP}:30001/v2/" >/dev/null 2>&1; then
                echo "Registry endpoint is reachable"
                break
              fi
              echo " Registry not yet reachable... ($i/30)"
              sleep 5
            done

            echo "Creating Harbor project: ${HARBOR_PROJECT}..."
            PROJECT_READY="false"
            for i in $(seq 1 30); do
              PROJECT_JSON=$(printf '{"project_name":"%s","metadata":{"public":"true"}}' "${HARBOR_PROJECT}")
              HTTP_CODE=$(curl -sk -o /tmp/harbor_create_resp.json -w '%{http_code}' \
                -X POST "https://${MASTER_IP}:30001/api/v2.0/projects" \
                -u "admin:${HARBOR_PASS}" \
                -H "Content-Type: application/json" \
                -d "$PROJECT_JSON")
              echo " Attempt $i/30 HTTP $HTTP_CODE"
              if [ "$HTTP_CODE" = "201" ] || [ "$HTTP_CODE" = "409" ]; then
                echo "Project ${HARBOR_PROJECT} ready"
                PROJECT_READY="true"
                break
              fi
              sleep 5
            done

            echo "Verifying project exists in API..."
            for i in $(seq 1 30); do
              VERIFY_PROJECT_CODE=$(curl -sk -o /dev/null -w '%{http_code}' -u "admin:${HARBOR_PASS}" "https://${MASTER_IP}:30001/api/v2.0/projects/${HARBOR_PROJECT}")
              if [ "$VERIFY_PROJECT_CODE" = "200" ]; then
                echo "Project verified"
                PROJECT_READY="true"
                break
              fi
              echo " Waiting for project to appear... ($i/30)"
              sleep 5
            done

            if [ "$PROJECT_READY" != "true" ]; then
              echo "ERROR: Harbor project ${HARBOR_PROJECT} was not created or verified; skipping image seeding"
              kubectl get pods -n harbor || true
              exit 1
            fi

            echo "Logging in to Harbor registry..."
            echo "${HARBOR_PASS}" | docker login "${MASTER_IP}:30001" -u admin --password-stdin || {
              echo "WARNING: Docker login failed"
            }

            for img in "${AIRGAP_IMAGES[@]}"; do
              echo "=== Processing: $img ==="
              norm="${img#docker.io/}"
              norm="${norm#registry.k8s.io/}"
              norm="${norm#quay.io/}"
              if [[ "$norm" == *":"* ]]; then
                repo="${norm%:*}"
                tag="${norm##*:}"
              else
                repo="$norm"
                tag="latest"
              fi
              repo="${repo#library/}"
              target="${MASTER_IP}:30001/${HARBOR_PROJECT}/${repo}:${tag}"
              echo " Target: $target"
              repo_api="${repo//\//%252F}"
              ARTIFACT_CODE=$(curl -sk -o /dev/null -w '%{http_code}' -u "admin:${HARBOR_PASS}" \
                "https://${MASTER_IP}:30001/api/v2.0/projects/${HARBOR_PROJECT}/repositories/${repo_api}/artifacts/${tag}")
              if [ "$ARTIFACT_CODE" = "200" ]; then
                echo " SKIP: Already exists in Harbor"
                continue
              fi
              echo " Pulling..."
              if ! docker pull "$img"; then
                echo " WARNING: Pull failed for $img, skipping"
                continue
              fi
              echo " Tagging..."
              docker tag "$img" "$target" || {
                echo " WARNING: Tag failed"
                continue
              }
              echo " Pushing..."
              if docker push "$target"; then
                echo " SUCCESS: $target"
              else
                echo " FAILED: $target"
              fi
            done

            echo "=========================================="
            echo "Image seeding complete!"
            echo "=========================================="

            # ============================================================
            # FIX 9: Write registries.yaml via Python with quoted heredoc
            # Uses <<'PYEOF' to prevent shell variable expansion
            # Variables passed as environment variables
            # ============================================================
            echo "Configuring K3s containerd registry via Python writer..."
            mkdir -p /etc/rancher/k3s

            export MASTER_IP_VAL="${MASTER_IP}"
            export HARBOR_PROJECT_VAL="${HARBOR_PROJECT}"
            export HARBOR_PASS_VAL="${HARBOR_PASS}"

            python3 <<'PYEOF'
import os
import sys
import yaml

master_ip   = os.environ.get('MASTER_IP_VAL', '192.168.121.114')
harbor_proj = os.environ.get('HARBOR_PROJECT_VAL', 'airgap')
harbor_pass = os.environ.get('HARBOR_PASS_VAL', 'Harbor12345')

content = f'''mirrors:
  "docker.io":
    endpoint:
      - "https://{master_ip}:30001"
    rewrite:
      "^rancher/(.*)": "{harbor_proj}/rancher/$1"
      "^library/(.*)": "{harbor_proj}/library/$1"
      "^(.*)": "{harbor_proj}/$1"
  "quay.io":
    endpoint:
      - "https://{master_ip}:30001"
    rewrite:
      "^(.*)": "{harbor_proj}/$1"
  "ghcr.io":
    endpoint:
      - "https://{master_ip}:30001"
    rewrite:
      "^kyverno/(.*)": "{harbor_proj}/kyverno/$1"
      "^(.*)": "{harbor_proj}/$1"
  "registry.k8s.io":
    endpoint:
      - "https://{master_ip}:30001"
    rewrite:
      "^(.*)": "{harbor_proj}/$1"
  "{master_ip}:30001":
    endpoint:
      - "https://{master_ip}:30001"

configs:
  "{master_ip}:30001":
    tls:
      insecure_skip_verify: true
    auth:
      username: admin
      password: {harbor_pass}
'''

with open('/etc/rancher/k3s/registries.yaml', 'w') as f:
    f.write(content)

# Validate YAML
data = yaml.safe_load(content)
print('VALID YAML - mirrors:', list(data.get('mirrors', {}).keys()))
sys.exit(0)
PYEOF

            if [ $? -eq 0 ]; then
              echo "Registries.yaml generated and validated successfully"
            else
              echo "ERROR: Failed to generate valid registries.yaml"
              exit 1
            fi

            echo "=== Final registries.yaml ==="
            cat /etc/rancher/k3s/registries.yaml
            echo "============================="

            systemctl restart k3s
            sleep 10
            echo "K3s registry configuration applied with clean YAML"

            # ============================================================
            # STRICT ZERO CACHE CLEANUP - NO LOCAL IMAGES AT ALL
            # ============================================================
            echo "=========================================="
            echo "Docker cache mode: ${CACHE_MODE} -> STRICT ZERO (No local images)"
            echo "=========================================="

            # Aggressive cleanup - remove everything
            docker image prune -a -f 2>/dev/null || true
            docker builder prune -a -f 2>/dev/null || true
            docker system prune -a -f 2>/dev/null || true

            if [ "${CACHE_MODE}" = "zero" ]; then
                echo "Removing ALL images from Docker (including Harbor ones)"

                # Remove everything
                docker images -q | xargs -r docker rmi -f 2>/dev/null || true
                docker images -q | xargs -r docker rmi -f 2>/dev/null || true

                echo "Docker is now completely clean. No images stored locally."
                echo "All pulls will go through Harbor."
            else
                echo "Warning: CACHE_MODE is not 'zero'. Using safe cleanup."
            fi

            echo "=========================================="
            echo "Final docker images:"
            docker images
            echo "=========================================="

            echo "Creating Kubernetes secret for Harbor registry pull access..."
            kubectl delete secret harbor-secret --ignore-not-found=true
            kubectl create secret docker-registry harbor-secret \
              --docker-server="${MASTER_IP}:30001" \
              --docker-username="admin" \
              --docker-password="${HARBOR_PASS}" \
              --docker-email="admin@example.com" \
              --namespace=default
            kubectl patch serviceaccount default -n default -p '{"imagePullSecrets": [{"name": "harbor-secret"}]}'
            echo "Harbor registry secret 'harbor-secret' created and configured for default service account"

            # ============================================================
            # FINAL VALIDATION - Confirm K3s pulls directly from Harbor
            # ============================================================
            echo "Running final test: Can K3s pull directly from Harbor?"
            kubectl delete pod test-busybox --ignore-not-found=true --grace-period=1 2>/dev/null || true
            sleep 2
            kubectl run test-busybox --image=${MASTER_IP}:30001/${HARBOR_PROJECT}/busybox:1.36 --command -- sleep 10

            if kubectl wait --for=condition=Ready pod/test-busybox --timeout=60s 2>/dev/null; then
                echo "SUCCESS: K3s successfully pulled image from Harbor!"
                kubectl delete pod test-busybox --ignore-not-found=true --grace-period=1 2>/dev/null || true
            else
                echo "FAILED: K3s could not pull from Harbor. Check Harbor and registries.yaml"
                kubectl describe pod test-busybox 2>/dev/null || true
                kubectl delete pod test-busybox --ignore-not-found=true --grace-period=1 2>/dev/null || true
            fi

            echo "=========================================="

            transition_state "harbor_installed"
          fi

          grep -q "${MASTER_IP}" /etc/rancher/k3s/k3s.yaml || sed -i "s/127.0.0.1/${MASTER_IP}/g" /etc/rancher/k3s/k3s.yaml
          cp /etc/rancher/k3s/k3s.yaml /vagrant/kubeconfig.yaml
          chmod 644 /vagrant/kubeconfig.yaml

          if [ ! -f /home/vagrant/.ssh/id_rsa ]; then
            ssh-keygen -t rsa -b 2048 -f /home/vagrant/.ssh/id_rsa -N ""
            cp /home/vagrant/.ssh/id_rsa.pub /vagrant/ansible_key.pub
          fi

          transition_state "base_complete"
          echo "=================================================="
          echo "BASE LAB READY (Profile: ${LAB_PROFILE})"
          echo "FAST_BOOT: ${FAST_BOOT}"
          echo "CACHE_MODE: ${CACHE_MODE}"
          echo "Harbor: https://${MASTER_IP}:30001 (admin / ${HARBOR_PASS})"
          echo "Harbor Project: ${HARBOR_PROJECT}"
          echo "=================================================="

          jobs -p | xargs -r kill 2>/dev/null || true
          sync
          echo "Provisioning complete - exiting cleanly"
          exit 0
        SHELL

        # ================= PROVISIONER 2: ENTERPRISE TOOLS =================
        vm.vm.provision "shell", inline: <<-SHELL
          if [ "${DEBUG:-false}" = "true" ]; then set -x; fi
          set -euo pipefail

          MASTER_IP="#{cfg[:ip]}"
          ARGOCD_VERSION="#{ARGOCD_VERSION}"
          PROMETHEUS_VERSION="#{PROMETHEUS_VERSION}"
          FALCO_VERSION="#{FALCO_VERSION}"
          KYVERNO_VERSION="#{KYVERNO_VERSION}"
          CERT_MANAGER_VERSION="#{CERT_MANAGER_VERSION}"
          TERRAFORM_VERSION="#{TERRAFORM_VERSION}"
          OPENTOFU_VERSION="#{OPENTOFU_VERSION}"
          FAST_BOOT="#{FAST_BOOT}"

          # ========== TERRAFORM INSTALLATION ==========
          TERRAFORM_MARKER="/var/lib/terraform_installed"

          if [ ! -f "$TERRAFORM_MARKER" ] || [ "${FAST_BOOT}" != "true" ]; then
            echo "=========================================="
            echo "INSTALLING TERRAFORM ${TERRAFORM_VERSION}"
            echo "=========================================="
            
            # Clean up any previous installations
            rm -f /usr/local/bin/terraform
            
            # Download and install Terraform
            TEMP_DIR=$(mktemp -d)
            cd "$TEMP_DIR"
            
            # FIX 4: Dynamic architecture detection
            ARCH=$(uname -m | sed 's/x86_64/amd64/' | sed 's/aarch64/arm64/')
            echo "Detected architecture: ${ARCH}"
            
            echo "Downloading Terraform ${TERRAFORM_VERSION} for ${ARCH}..."
            curl -fsSL "https://releases.hashicorp.com/terraform/${TERRAFORM_VERSION}/terraform_${TERRAFORM_VERSION}_linux_${ARCH}.zip" -o terraform.zip
            
            echo "Extracting Terraform..."
            apt-get install -y unzip 2>/dev/null || dnf install -y unzip 2>/dev/null || zypper install -y unzip 2>/dev/null || true
            unzip -q terraform.zip
            
            echo "Installing Terraform to /usr/local/bin..."
            mv terraform /usr/local/bin/
            chmod +x /usr/local/bin/terraform
            
            # Verify installation
            if command -v terraform >/dev/null 2>&1; then
              TERRAFORM_INSTALLED_VERSION=$(terraform version -json 2>/dev/null | grep -o '"terraform_version":"[^"]*"' | cut -d'"' -f4 || terraform version | head -1)
              echo "Terraform installed successfully: ${TERRAFORM_INSTALLED_VERSION}"
              
              # Enable bash completion
              terraform -install-autocomplete 2>/dev/null || true
              
              # Create marker file
              touch "$TERRAFORM_MARKER"
            else
              echo "ERROR: Terraform installation failed"
              exit 1
            fi
            
            # Cleanup
            cd /
            rm -rf "$TEMP_DIR"
            
            echo "=========================================="
            echo "Terraform is ready to use!"
            echo "Run 'terraform --version' to verify"
            echo "=========================================="
          else
            echo "Terraform already installed, skipping (FAST_BOOT=true)"
          fi
          # ========== END TERRAFORM INSTALLATION ==========

          # ========== OPENTOFU INSTALLATION ==========
          OPENTOFU_MARKER="/var/lib/opentofu_installed"

          if [ ! -f "$OPENTOFU_MARKER" ] || [ "${FAST_BOOT}" != "true" ]; then
            echo "=========================================="
            echo "INSTALLING OPENTOFU ${OPENTOFU_VERSION}"
            echo "=========================================="
            
            # Clean up any previous installations
            rm -f /usr/local/bin/tofu
            
            # Download and install OpenTofu
            TEMP_DIR=$(mktemp -d)
            cd "$TEMP_DIR"
            
            ARCH=$(uname -m | sed 's/x86_64/amd64/' | sed 's/aarch64/arm64/')
            echo "Detected architecture: ${ARCH}"
            
            echo "Downloading OpenTofu ${OPENTOFU_VERSION} for ${ARCH}..."
            curl -fsSL "https://github.com/opentofu/opentofu/releases/download/v${OPENTOFU_VERSION}/tofu_${OPENTOFU_VERSION}_linux_${ARCH}.zip" -o tofu.zip
            
            echo "Extracting OpenTofu..."
            apt-get install -y unzip 2>/dev/null || dnf install -y unzip 2>/dev/null || zypper install -y unzip 2>/dev/null || true
            unzip -q tofu.zip
            
            echo "Installing OpenTofu to /usr/local/bin..."
            mv tofu /usr/local/bin/
            chmod +x /usr/local/bin/tofu
            
            # Verify installation
            if command -v tofu >/dev/null 2>&1; then
              TOFU_VERSION=$(tofu version -json 2>/dev/null | grep -o '"version":"[^"]*"' | cut -d'"' -f4 || tofu version | head -1)
              echo "OpenTofu installed successfully: ${TOFU_VERSION}"
              
              # Enable bash completion
              tofu -install-autocomplete 2>/dev/null || true
              
              # Create marker file
              touch "$OPENTOFU_MARKER"
            else
              echo "ERROR: OpenTofu installation failed"
              exit 1
            fi
            
            # Cleanup
            cd /
            rm -rf "$TEMP_DIR"
            
            echo "=========================================="
            echo "OpenTofu is ready to use!"
            echo "Run 'tofu --version' to verify"
            echo ""
            echo "You can now use either:"
            echo "  terraform init && terraform plan"
            echo "  tofu init && tofu plan"
            echo "=========================================="
          else
            echo "OpenTofu already installed, skipping (FAST_BOOT=true)"
          fi
          # ========== END OPENTOFU INSTALLATION ==========

          export PATH=$PATH:/usr/local/bin
          export KUBECONFIG=/etc/rancher/k3s/k3s.yaml

          # Individual tool markers for granular retry capability
          ENTERPRISE_MARKER="/var/lib/enterprise_tools_installed"
          CERTS_MARKER="/var/lib/cert_manager_installed"
          KYVERNO_MARKER="/var/lib/kyverno_installed"
          FALCO_MARKER="/var/lib/falco_installed"
          PROMETHEUS_MARKER="/var/lib/prometheus_installed"
          ARGOCD_MARKER="/var/lib/argocd_installed"

          # If the old marker exists, respect it for backward compatibility
          if [ -f "$ENTERPRISE_MARKER" ]; then
            echo "Enterprise tools already installed (legacy marker), skipping"
            exit 0
          fi

          echo "=========================================="
          echo "INSTALLING ENTERPRISE DEVSECOPS TOOLS"
          echo "=========================================="

          if [ "${FAST_BOOT}" != "true" ]; then

            # ============================================================
            # 1. CERT-MANAGER (Certificate Management)
            # ============================================================
            if [ ! -f "$CERTS_MARKER" ]; then
              echo "Installing cert-manager ${CERT_MANAGER_VERSION}..."
              kubectl apply -f "https://github.com/cert-manager/cert-manager/releases/download/v${CERT_MANAGER_VERSION}/cert-manager.yaml"
              echo "Waiting for cert-manager pods..."
              for i in $(seq 1 60); do
                if kubectl get pods -n cert-manager --no-headers 2>/dev/null | grep -q Running; then
                  echo "cert-manager is ready"
                  break
                fi
                echo " Waiting for cert-manager... ($i/60)"
                sleep 5
              done
              touch "$CERTS_MARKER"
            else
              echo "cert-manager already installed, skipping"
            fi

            # ============================================================
            # 2. KYVERNO (Policy Enforcement) - Added retry logic
            # ============================================================
            if [ ! -f "$KYVERNO_MARKER" ]; then
              echo "Installing Kyverno ${KYVERNO_VERSION}..."
              
              # Clean up any existing Kyverno resources
              helm uninstall kyverno -n kyverno 2>/dev/null || true
              kubectl delete namespace kyverno --ignore-not-found=true
              sleep 10
              
              helm repo add kyverno https://kyverno.github.io/kyverno/ --force-update
              helm repo update
              
              # Install with retry logic for image pull issues
              INSTALL_SUCCESS=false
              for attempt in 1 2 3; do
                echo "Kyverno install attempt $attempt/3..."
                if helm upgrade --install kyverno kyverno/kyverno \
                  --namespace kyverno \
                  --create-namespace \
                  --version ${KYVERNO_VERSION} \
                  --set installCRDs=true \
                  --wait \
                  --timeout 10m 2>/dev/null; then
                  INSTALL_SUCCESS=true
                  echo "Kyverno installed successfully on attempt $attempt"
                  break
                else
                  echo "Kyverno attempt $attempt failed, waiting 30s before retry..."
                  kubectl delete namespace kyverno --ignore-not-found=true 2>/dev/null || true
                  sleep 30
                fi
              done
              
              if [ "$INSTALL_SUCCESS" = "false" ]; then
                echo "WARNING: Kyverno install had issues - continuing anyway"
                # Try one more time without waiting
                helm upgrade --install kyverno kyverno/kyverno \
                  --namespace kyverno \
                  --create-namespace \
                  --version ${KYVERNO_VERSION} \
                  --set installCRDs=true || true
              fi

              echo "Waiting for Kyverno pods..."
              for i in $(seq 1 120); do
                RUNNING_COUNT=$(kubectl get pods -n kyverno --no-headers 2>/dev/null | grep -c Running || echo "0")
                TOTAL_COUNT=$(kubectl get pods -n kyverno --no-headers 2>/dev/null | wc -l || echo "0")
                if [ "$TOTAL_COUNT" -gt 0 ] && [ "$RUNNING_COUNT" -eq "$TOTAL_COUNT" ]; then
                  echo "All Kyverno pods are ready ($RUNNING_COUNT/$TOTAL_COUNT)"
                  break
                fi
                echo " Waiting for Kyverno... ($i/120) - $RUNNING_COUNT/$TOTAL_COUNT running"
                sleep 10
              done
              touch "$KYVERNO_MARKER"
            else
              echo "Kyverno already installed, skipping"
            fi

            # ============================================================
            # 3. FALCO (Runtime Security)
            # ============================================================
            if [ ! -f "$FALCO_MARKER" ]; then
              echo "Installing Falco ${FALCO_VERSION}..."
              helm repo add falcosecurity https://falcosecurity.github.io/charts --force-update
              helm repo update
              helm upgrade --install falco falcosecurity/falco \
                --namespace falco \
                --create-namespace \
                --version ${FALCO_VERSION} \
                --set falco.jsonOutput=true \
                --set falco.fileOutput.enabled=true \
                --set falco.fileOutput.json=true \
                --wait \
                --timeout 10m || echo "WARNING: Falco install had issues"
              touch "$FALCO_MARKER"
            else
              echo "Falco already installed, skipping"
            fi

            # ============================================================
            # 4. PROMETHEUS + GRAFANA (Observability) - WITH AUTO-ASSIGN PORT
            # ============================================================
            if [ ! -f "$PROMETHEUS_MARKER" ]; then
              echo "Installing Prometheus Stack ${PROMETHEUS_VERSION}..."

              # Clean up any existing Grafana service that might be using a fixed port
              kubectl delete svc prometheus-stack-grafana -n monitoring --ignore-not-found=true

              helm repo add prometheus-community https://prometheus-community.github.io/helm-charts --force-update
              helm repo update

              cat > /tmp/prometheus-values.yaml <<EOF
prometheus:
  prometheusSpec:
    serviceMonitorSelectorNilUsesHelmValues: false
    serviceMonitorSelector: {}
    serviceMonitorNamespaceSelector: {}
grafana:
  adminPassword: admin
  service:
    type: NodePort
  persistence:
    enabled: true
    size: 1Gi
alertmanager:
  enabled: true
EOF

              helm upgrade --install prometheus-stack prometheus-community/kube-prometheus-stack \
                --namespace monitoring \
                --create-namespace \
                --version ${PROMETHEUS_VERSION} \
                --values /tmp/prometheus-values.yaml \
                --wait \
                --timeout 15m || echo "WARNING: Prometheus stack install had issues"

              echo "Waiting for Prometheus and Grafana pods..."
              for i in $(seq 1 90); do
                if kubectl get pods -n monitoring --no-headers 2>/dev/null | grep -q Running; then
                  RUNNING_COUNT=$(kubectl get pods -n monitoring --no-headers | grep -c Running || echo "0")
                  TOTAL_COUNT=$(kubectl get pods -n monitoring --no-headers | wc -l || echo "0")
                  echo " Monitoring pods: $RUNNING_COUNT/$TOTAL_COUNT running... ($i/90)"
                  if [ "$RUNNING_COUNT" -eq "$TOTAL_COUNT" ] && [ "$TOTAL_COUNT" -gt 5 ]; then
                    echo "All monitoring pods are ready"
                    break
                  fi
                fi
                sleep 10
              done

              # Get the auto-assigned Grafana port
              GRAFANA_PORT=$(kubectl get svc -n monitoring prometheus-stack-grafana -o jsonpath='{.spec.ports[0].nodePort}' 2>/dev/null || echo "30002")
              echo "Grafana will be available at: https://${MASTER_IP}:${GRAFANA_PORT} (admin/admin)"
              touch "$PROMETHEUS_MARKER"
            else
              echo "Prometheus stack already installed, skipping"
              # Still get the port for display
              GRAFANA_PORT=$(kubectl get svc -n monitoring prometheus-stack-grafana -o jsonpath='{.spec.ports[0].nodePort}' 2>/dev/null || echo "30002")
            fi

            # ============================================================
            # 5. ARGO CD (GitOps) - CLEAN INSTALL WITH FULL CLUSTER CLEANUP
            # ============================================================
            if [ ! -f "$ARGOCD_MARKER" ]; then
              echo "Installing Argo CD ${ARGOCD_VERSION}..."

              # ============================================================
              # CLEAN OLD ARGO CD RESOURCES (VERY IMPORTANT)
              # ============================================================
              echo "Cleaning old Argo CD resources..."

              helm uninstall argocd -n argocd 2>/dev/null || true

              kubectl delete namespace argocd --ignore-not-found=true

              # Delete applications first then CRDs with --wait=false to prevent hangs
              kubectl delete applications --all -n argocd --ignore-not-found=true --wait=false 2>/dev/null || true
              
              # Delete CRDs with --wait=false to prevent finalizer hangs
              kubectl delete crd applications.argoproj.io --ignore-not-found=true --wait=false 2>/dev/null || true
              kubectl delete crd appprojects.argoproj.io --ignore-not-found=true --wait=false 2>/dev/null || true
              kubectl delete crd applicationsets.argoproj.io --ignore-not-found=true --wait=false 2>/dev/null || true
              kubectl delete crd argocdextensions.argoproj.io --ignore-not-found=true --wait=false 2>/dev/null || true

              # Delete cluster roles
              kubectl delete clusterrole argocd-application-controller --ignore-not-found=true 2>/dev/null || true
              kubectl delete clusterrole argocd-server --ignore-not-found=true 2>/dev/null || true
              kubectl delete clusterrole argocd-dex-server --ignore-not-found=true 2>/dev/null || true
              kubectl delete clusterrole argocd-notifications-controller --ignore-not-found=true 2>/dev/null || true
              kubectl delete clusterrole argocd-redis-ha-haproxy --ignore-not-found=true 2>/dev/null || true
              kubectl delete clusterrole argocd-redis-ha-server --ignore-not-found=true 2>/dev/null || true

              # Delete cluster role bindings
              kubectl delete clusterrolebinding argocd-application-controller --ignore-not-found=true 2>/dev/null || true
              kubectl delete clusterrolebinding argocd-server --ignore-not-found=true 2>/dev/null || true
              kubectl delete clusterrolebinding argocd-dex-server --ignore-not-found=true 2>/dev/null || true
              kubectl delete clusterrolebinding argocd-notifications-controller --ignore-not-found=true 2>/dev/null || true

              # Delete webhook configs
              kubectl delete validatingwebhookconfiguration argocd-application-controller --ignore-not-found=true 2>/dev/null || true
              kubectl delete mutatingwebhookconfiguration argocd-application-controller --ignore-not-found=true 2>/dev/null || true

              # Give Kubernetes time to fully clean up
              sleep 30

              # Install Argo CD using Helm (clean install)
              echo "Installing Argo CD using Helm..."
              helm repo add argo https://argoproj.github.io/argo-helm --force-update
              helm repo update

              helm upgrade --install argocd argo/argo-cd \
                --namespace argocd \
                --create-namespace \
                --version ${ARGOCD_VERSION} \
                --set server.service.type=NodePort \
                --set server.service.servicePortHttp=80 \
                --set server.service.servicePortHttps=443 \
                --set server.service.nodePortHttp=30003 \
                --set server.service.nodePortHttps=30004 \
                --wait \
                --timeout 10m || echo "WARNING: Argo CD install had issues"

              echo "Waiting for Argo CD pods..."
              for i in $(seq 1 120); do
                if kubectl get pods -n argocd --no-headers 2>/dev/null | grep -q Running; then
                  RUNNING_COUNT=$(kubectl get pods -n argocd --no-headers | grep -c Running || echo "0")
                  TOTAL_COUNT=$(kubectl get pods -n argocd --no-headers | wc -l || echo "0")
                  echo " Argo CD pods: $RUNNING_COUNT/$TOTAL_COUNT running... ($i/120)"
                  if [ "$RUNNING_COUNT" -eq "$TOTAL_COUNT" ] && [ "$TOTAL_COUNT" -gt 5 ]; then
                    echo "All Argo CD pods are ready"
                    break
                  fi
                fi
                sleep 10
              done

              echo ""
              echo "=========================================="
              echo "Argo CD initial admin password:"
              kubectl -n argocd get secret argocd-initial-admin-secret -o jsonpath="{.data.password}" 2>/dev/null | base64 -d || echo "Password extraction failed, check manually"
              echo ""
              echo "=========================================="
              touch "$ARGOCD_MARKER"
            else
              echo "Argo CD already installed, skipping"
            fi

            # ============================================================
            # CREATE INGRESS FOR GRAFANA
            # ============================================================
            cat > /tmp/grafana-ingress.yaml <<EOF
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: grafana
  namespace: monitoring
spec:
  rules:
  - host: grafana.local
    http:
      paths:
      - pathType: Prefix
        path: "/"
        backend:
          service:
            name: prometheus-stack-grafana
            port:
              number: 80
EOF

            kubectl apply -f /tmp/grafana-ingress.yaml 2>/dev/null || true

            # ============================================================
            # INSTALL K9S, KUBECTX, KUBENS, STERN (Day-2 Tools)
            # ============================================================
            echo "Installing kubectx, kubens, stern, and k9s..."

            # Install kubectx and kubens
            git clone https://github.com/ahmetb/kubectx /opt/kubectx 2>/dev/null || true
            ln -sf /opt/kubectx/kubectx /usr/local/bin/kubectx
            ln -sf /opt/kubectx/kubens /usr/local/bin/kubens

            # Install stern
            curl -sSLo /usr/local/bin/stern "https://github.com/stern/stern/releases/download/v1.28.0/stern_linux_amd64" && \
              chmod +x /usr/local/bin/stern

            # Install k9s
            curl -sSLo /tmp/k9s.tar.gz "https://github.com/derailed/k9s/releases/download/v0.32.5/k9s_Linux_amd64.tar.gz" && \
              tar -xzf /tmp/k9s.tar.gz -C /usr/local/bin k9s && \
              chmod +x /usr/local/bin/k9s

            echo "Day-2 tools installed: kubectx, kubens, stern, k9s"

            echo "=========================================="
            echo "ENTERPRISE TOOLS INSTALLATION COMPLETE"
            echo "=========================================="
            echo ""
            echo "cert-manager: TLS certificate management"
            echo "Kyverno: Policy enforcement"
            echo "Falco: Runtime security"
            echo "Prometheus: Metrics collection (port 9090 via port-forward)"
            echo "Grafana: https://${MASTER_IP}:${GRAFANA_PORT} (admin/admin)"
            echo "Argo CD: https://${MASTER_IP}:30003 (admin / password above)"
            echo "Terraform: $(terraform version | head -1)"
            echo "OpenTofu: $(tofu version | head -1)"
            echo ""
            echo "To access services:"
            echo " Grafana: https://${MASTER_IP}:${GRAFANA_PORT}"
            echo " Argo CD: https://${MASTER_IP}:30003"
            echo ""
            echo "Port-forward alternatives:"
            echo " kubectl port-forward -n monitoring svc/prometheus-stack-grafana 3000:80"
            echo " kubectl port-forward -n argocd svc/argocd-server 8080:443"
            echo "=========================================="
          fi

          # Keep the original marker for backward compatibility
          touch "$ENTERPRISE_MARKER"
        SHELL

      when "worker"
        vm.vm.provision "shell", inline: <<-SHELL
          if [ "${DEBUG:-false}" = "true" ]; then set -x; fi
          set -euo pipefail

          MASTER="#{MASTER_IP}"
          WORKER_IP="#{cfg[:ip]}"
          WORKER_NAME="#{name}"
          TOKEN_FILE=/vagrant/.k3s_token
          CLUSTER_STATE=/vagrant/.cluster_state.json
          KUBECONFIG_PATH=/vagrant/kubeconfig.yaml

          export PATH=$PATH:/usr/local/bin:/var/lib/rancher/k3s/bin

          get_iface() {
            local ip="$1"
            iface=$(ip route show default 2>/dev/null | awk '/default/ {print $5; exit}')
            if [ -z "$iface" ]; then
              iface=$(ip route get "$ip" 2>/dev/null | awk '/dev/ {for(i=1;i<=NF;i++) if($i=="dev") print $(i+1)}' | head -n1)
            fi
            if [ -z "$iface" ]; then
              iface=$(ip -o link show | awk -F': ' '$2 ~ /^(ens|enp|eth)/ {print $2; exit}')
            fi
            [ -z "$iface" ] && iface="eth0"
            echo "$iface"
          }

          echo "Configuring kernel modules for Kubernetes..."
          modprobe br_netfilter || true
          modprobe overlay || true
          modprobe vxlan || true
          cat <<EOF >/etc/modules-load.d/k8s.conf
overlay
br_netfilter
vxlan
EOF
          echo br_netfilter | tee /etc/modules-load.d/br_netfilter.conf >/dev/null
          cat <<EOF >/etc/sysctl.d/99-kubernetes.conf
net.bridge.bridge-nf-call-iptables=1
net.bridge.bridge-nf-call-ip6tables=1
net.ipv4.ip_forward=1
net.ipv4.conf.all.rp_filter=0
net.ipv4.conf.default.rp_filter=0
EOF
          sysctl --system
          apt-get install -y iptables arptables ebtables 2>/dev/null || true
          update-alternatives --set iptables /usr/sbin/iptables-legacy 2>/dev/null || true
          update-alternatives --set ip6tables /usr/sbin/ip6tables-legacy 2>/dev/null || true
          swapoff -a || true
          sed -i '/ swap / s/^/#/' /etc/fstab 2>/dev/null || true

          echo "Waiting for master cluster ready signal..."
          until [ -f "$CLUSTER_STATE" ] && grep -q '"cluster_ready": true' "$CLUSTER_STATE" 2>/dev/null; do
            echo " Waiting for cluster ready..."; sleep 8
          done
          sleep 15

          if [ ! -s "$TOKEN_FILE" ]; then
            echo "ERROR: K3s token file is missing or empty: $TOKEN_FILE"
            exit 1
          fi
          TOKEN=$(cat "$TOKEN_FILE")

          if systemctl is-active --quiet k3s-agent 2>/dev/null; then
            echo "Worker already joined"
            exit 0
          fi

          IFACE=$(get_iface "${WORKER_IP}")
          echo "Detected interface for worker: ${IFACE}"

          # FIX 3: Remove invalid --flannel-backend flag (only valid for server)
          curl -sfL https://get.k3s.io | INSTALL_K3S_EXEC="agent \
            --node-name ${WORKER_NAME} \
            --server https://$MASTER:6443 \
            --token $TOKEN \
            --node-ip $WORKER_IP" sh -

          systemctl enable --now k3s-agent || true
          echo "Worker ${WORKER_NAME} joined successfully"
        SHELL

      when "lab", "ansible"
        vm.vm.provision "shell", inline: <<-SHELL
          set -euo pipefail
          mkdir -p /home/vagrant/.ssh
          chmod 700 /home/vagrant/.ssh

          for i in $(seq 1 30); do
            if [ -f /vagrant/ansible_key.pub ]; then
              grep -qF "$(cat /vagrant/ansible_key.pub)" /home/vagrant/.ssh/authorized_keys 2>/dev/null || \
              cat /vagrant/ansible_key.pub >> /home/vagrant/.ssh/authorized_keys
              chmod 600 /home/vagrant/.ssh/authorized_keys
              echo "SSH key configured for $(hostname)"
              break
            fi
            echo " Waiting for ansible_key.pub... ($i/30)"; sleep 2
          done
        SHELL

      # ================= KIND LAB PROVISIONING =================
      when "kind"
        # Port forward for Kind API
        vm.vm.network "forwarded_port", guest: 6443, host: 26443, host_ip: "127.0.0.1"

        # Ensure Docker is running
        vm.vm.provision "shell", inline: <<-SHELL
          systemctl enable --now docker 2>/dev/null || true
          usermod -aG docker vagrant 2>/dev/null || true
        SHELL

        # Install and setup Kind (fully automated)
        vm.vm.provision "shell", inline: <<-SHELL
          set -euo pipefail

          KIND_VERSION="${KIND_VERSION:-v0.24.0}"
          KUBECTL_VERSION="${KUBECTL_VERSION:-v1.31.0}"
          FAST_BOOT="${FAST_BOOT:-false}"
          MARKER_FILE="/var/lib/kind_installed"

          if [ -f "$MARKER_FILE" ] && [ "$FAST_BOOT" = "true" ]; then
            echo "Kind already installed, skipping (FAST_BOOT=true)"
            exit 0
          fi

          echo "=========================================="
          echo "INSTALLING KIND (Kubernetes in Docker)"
          echo "=========================================="

          # Install kubectl if not present
          if ! command -v kubectl >/dev/null 2>&1; then
            echo "Installing kubectl ${KUBECTL_VERSION}..."
            curl -fsSL "https://dl.k8s.io/release/${KUBECTL_VERSION}/bin/linux/amd64/kubectl" -o /usr/local/bin/kubectl
            chmod +x /usr/local/bin/kubectl
            echo 'source <(kubectl completion bash)' >> /home/vagrant/.bashrc
          fi

          # Install kind
          echo "Installing kind ${KIND_VERSION}..."
          curl -fsSL "https://kind.sigs.k8s.io/dl/${KIND_VERSION}/kind-linux-amd64" -o /usr/local/bin/kind
          chmod +x /usr/local/bin/kind

          # Create kind configuration
          mkdir -p /opt/kind

          cat > /opt/kind/config.yaml <<'EOF'
kind: Cluster
apiVersion: kind.x-k8s.io/v1alpha4
nodes:
- role: control-plane
- role: worker
- role: worker
networking:
  apiServerAddress: "0.0.0.0"
  apiServerPort: 6443
EOF

          echo ""
          echo "Creating Kind cluster automatically..."
          echo "=========================================="

          # Clean up existing cluster if any
          kind delete cluster --name lab 2>/dev/null || true

          # Create new cluster
          if kind create cluster --config /opt/kind/config.yaml --name lab; then
            echo "Kind cluster 'lab' created successfully!"
            
            # Set up kubeconfig
            mkdir -p /home/vagrant/.kube
            kind get kubeconfig --name lab > /home/vagrant/.kube/config
            chown -R vagrant:vagrant /home/vagrant/.kube
            
            echo ""
            echo "Cluster status:"
            kubectl cluster-info
            kubectl get nodes
            
            # Create convenience aliases
            cat >> /home/vagrant/.bashrc <<'EOF'
# Kind aliases
alias kind-kill='kind delete cluster --name lab'
alias kind-restart='kind delete cluster --name lab && kind create cluster --config /opt/kind/config.yaml --name lab'
alias kind-status='kubectl get nodes && kubectl get pods -A'
EOF
            
          else
            echo "ERROR: Kind cluster creation failed"
            exit 1
          fi

          touch "$MARKER_FILE"

          echo ""
          echo "=========================================="
          echo "Kind installed and cluster running!"
          echo ""
          echo "Access the Kind cluster:"
          echo "  kubectl get nodes"
          echo "  kubectl get pods -A"
          echo ""
          echo "Useful commands:"
          echo "  kind-kill     - Delete the cluster"
          echo "  kind-restart  - Restart the cluster"
          echo "  kind-status   - Show cluster status"
          echo "=========================================="
        SHELL

      # ================= K3D LAB PROVISIONING =================
      when "k3d"
        # Port forward for K3d API and services
        vm.vm.network "forwarded_port", guest: 6443, host: 26444, host_ip: "127.0.0.1"
        vm.vm.network "forwarded_port", guest: 8080, host: 28080, host_ip: "127.0.0.1"

        # Ensure Docker is running
        vm.vm.provision "shell", inline: <<-SHELL
          systemctl enable --now docker 2>/dev/null || true
          usermod -aG docker vagrant 2>/dev/null || true
        SHELL

        # Install and setup K3d (fully automated)
        vm.vm.provision "shell", inline: <<-SHELL
          set -euo pipefail

          K3D_VERSION="${K3D_VERSION:-v5.7.5}"
          KUBECTL_VERSION="${KUBECTL_VERSION:-v1.31.0}"
          FAST_BOOT="${FAST_BOOT:-false}"
          MARKER_FILE="/var/lib/k3d_installed"

          if [ -f "$MARKER_FILE" ] && [ "$FAST_BOOT" = "true" ]; then
            echo "K3d already installed, skipping (FAST_BOOT=true)"
            exit 0
          fi

          echo "=========================================="
          echo "INSTALLING K3D (K3s in Docker)"
          echo "=========================================="

          # Install kubectl if not present
          if ! command -v kubectl >/dev/null 2>&1; then
            echo "Installing kubectl ${KUBECTL_VERSION}..."
            curl -fsSL "https://dl.k8s.io/release/${KUBECTL_VERSION}/bin/linux/amd64/kubectl" -o /usr/local/bin/kubectl
            chmod +x /usr/local/bin/kubectl
            echo 'source <(kubectl completion bash)' >> /home/vagrant/.bashrc
          fi

          # Install k3d
          echo "Installing k3d ${K3D_VERSION}..."
          curl -fsSL https://raw.githubusercontent.com/k3d-io/k3d/main/install.sh | TAG=${K3D_VERSION} bash

          # Install helm (optional but useful)
          if ! command -v helm >/dev/null 2>&1; then
            echo "Installing helm..."
            curl -fsSL https://raw.githubusercontent.com/helm/helm/main/scripts/get-helm-3 | bash
          fi

          # Create k3d configuration
          mkdir -p /opt/k3d

          cat > /opt/k3d/config.yaml <<'EOF'
apiVersion: k3d.io/v1alpha5
kind: Simple
metadata:
  name: lab
servers: 1
agents: 2
ports:
  - port: 8080:80@loadbalancer
  - port: 8443:443@loadbalancer
options:
  k3d:
    wait: true
    timeout: 60s
  k3s:
    extraArgs:
      - arg: --disable=traefik
        nodeFilters:
          - server:*
EOF

          echo ""
          echo "Creating K3d cluster automatically..."
          echo "=========================================="

          # Clean up existing cluster if any
          k3d cluster delete lab 2>/dev/null || true

          # Create new cluster
          if k3d cluster create lab --config /opt/k3d/config.yaml; then
            echo "K3d cluster 'lab' created successfully!"
            
            # Set up kubeconfig
            mkdir -p /home/vagrant/.kube
            k3d kubeconfig get lab > /home/vagrant/.kube/config
            chown -R vagrant:vagrant /home/vagrant/.kube
            
            echo ""
            echo "Cluster status:"
            kubectl cluster-info
            kubectl get nodes
            
            # Create convenience aliases
            cat >> /home/vagrant/.bashrc <<'EOF'
# K3d aliases
alias k3d-kill='k3d cluster delete lab'
alias k3d-restart='k3d cluster delete lab && k3d cluster create lab --config /opt/k3d/config.yaml'
alias k3d-status='kubectl get nodes && kubectl get pods -A'
EOF
            
          else
            echo "ERROR: K3d cluster creation failed"
            exit 1
          fi

          touch "$MARKER_FILE"

          echo ""
          echo "=========================================="
          echo "K3d installed and cluster running!"
          echo ""
          echo "Access the K3d cluster:"
          echo "  kubectl get nodes"
          echo "  kubectl get pods -A"
          echo ""
          echo "Useful commands:"
          echo "  k3d-kill     - Delete the cluster"
          echo "  k3d-restart  - Restart the cluster"
          echo "  k3d-status   - Show cluster status"
          echo "=========================================="
        SHELL
      end
    end
  end
end
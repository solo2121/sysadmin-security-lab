# -*- mode: ruby -*-
# vi: set ft=ruby :

ENV['LIBVIRT_DEFAULT_URI'] = 'qemu:///system'
Vagrant.require_version ">= 2.2.0"

DEFAULT = { memory: 1024, cpus: 1 }.freeze

def libvirt(vm, opts = {})
  c = DEFAULT.merge(opts)
  vm.vm.provider :libvirt do |l|
    l.memory = c[:memory]
    l.cpus = c[:cpus]
    l.nested = true
    l.graphics_type = "vnc"
    l.graphics_ip = "127.0.0.1"
  end
end

def attach_lab_disks(vm)
  vm.vm.provider :libvirt do |l|
    l.storage :file, size: "5G", type: "qcow2"
    l.storage :file, size: "5G", type: "qcow2"
    l.storage :file, size: "2G", type: "qcow2"
  end
end

Vagrant.configure("2") do |config|
  config.vm.box_check_update = false
  config.vm.synced_folder ".", "/vagrant", disabled: false

  cluster = {
    "devops-1" => { box: "bento/ubuntu-24.04", ip: "192.168.56.10", memory: 6144, cpus: 4 },
    "worker-1" => { box: "bento/ubuntu-24.04", ip: "192.168.56.11", memory: 3072, cpus: 2 },
    "worker-2" => { box: "bento/ubuntu-24.04", ip: "192.168.56.12", memory: 3072, cpus: 2 }
  }

  linux_labs = {
    "ubuntu-lab" => { box: "bento/ubuntu-24.04", ip: "192.168.56.20" },
    "rocky-lab"  => { box: "rockylinux/10",      ip: "192.168.56.21" },
    "alma-lab"   => { box: "almalinux/10",       ip: "192.168.56.22" },
    "suse-lab"   => { box: "opensuse/Leap-15.6", ip: "192.168.56.23" }
  }

  ansible_nodes = {
    "node1" => "192.168.56.30",
    "node2" => "192.168.56.31"
  }

  all_hosts = cluster.merge(linux_labs).merge(ansible_nodes.transform_values { |ip| { ip: ip } })
  hosts_entries = all_hosts.map { |n, d| "#{d[:ip]} #{n}" }.join("\n")

  config.vm.provision "shell", run: "always", inline: <<-SHELL
    set -e
    START="# LAB START"
    END="# LAB END"
    sed -i "/$START/,/$END/d" /etc/hosts || true
    cat >> /etc/hosts <<EOF
$START
#{hosts_entries}
$END
EOF
  SHELL

  (cluster.merge(linux_labs)).each do |name, cfg|
    config.vm.define name do |vm|
      vm.vm.box = cfg[:box]
      vm.vm.hostname = name
      vm.vm.network "private_network", ip: cfg[:ip]

      libvirt(vm, memory: cfg[:memory] || 1024, cpus: cfg[:cpus] || 1)
      attach_lab_disks(vm) if linux_labs.key?(name)

      vm.vm.provision "shell", inline: <<-SHELL
        set -euo pipefail
        export DEBIAN_FRONTEND=noninteractive

        if command -v apt-get >/dev/null; then
          apt-get update -qq
          apt-get install -y curl wget git jq vim tree tmux htop net-tools ca-certificates bash-completion python3 python3-pip
        elif command -v dnf >/dev/null; then
          dnf install -y curl wget git jq vim tree tmux htop net-tools ca-certificates bash-completion python3 python3-pip
        elif command -v zypper >/dev/null; then
          zypper install -y curl wget git jq vim tree tmux htop net-tools ca-certificates bash-completion python3 python3-pip
        fi

        systemctl enable --now ssh 2>/dev/null || true
      SHELL

      if name == "devops-1"
        vm.vm.network "forwarded_port", guest: 30080, host: 30080
        vm.vm.network "forwarded_port", guest: 32000, host: 32000
        vm.vm.network "forwarded_port", guest: 32001, host: 32001

        vm.vm.provision "shell", inline: <<-'SHELL'
          set -euo pipefail
          MASTER_IP=192.168.56.10

          # Docker
          if ! command -v docker >/dev/null; then
            curl -fsSL https://get.docker.com | sh
          fi
          systemctl enable --now docker
          usermod -aG docker vagrant || true

          # ==================== OFFLINE IMAGES (Modern 2026 Set) ====================
          docker pull alpine:latest || true
          docker pull busybox:latest || true
          docker pull nginx:alpine || true
          docker pull redis:alpine || true
          docker pull postgres:16-alpine || true
          docker pull python:3.11-slim || true
          docker pull node:20-alpine || true
          docker pull prom/prometheus || true
          docker pull grafana/grafana || true
          docker pull prom/node-exporter || true
          docker pull aquasec/trivy || true
          docker pull bitnami/kubectl || true
          docker pull hashicorp/vault || true
          docker pull argoproj/argocd || true

          # Extended DevSecOps Images
          docker pull registry:2 || true
          docker pull bitnami/minio || true
          docker pull rabbitmq:3-management || true
          docker pull mongo:7 || true
          docker pull curlimages/curl || true
          docker pull jenkins/jenkins:lts-jdk17 || true
          docker pull sonarqube:community || true
          docker pull traefik:v3.0 || true
          docker pull bitnami/kafka || true

          # ==================== TOOLS ====================
          # kubectl
          if ! command -v kubectl >/dev/null; then
            curl -LO "https://dl.k8s.io/release/$(curl -Ls https://dl.k8s.io/release/stable.txt)/bin/linux/amd64/kubectl"
            install -m 0755 kubectl /usr/local/bin/kubectl
            rm -f kubectl
          fi

          # Helm
          if ! command -v helm >/dev/null; then
            curl -fsSL https://raw.githubusercontent.com/helm/helm/main/scripts/get-helm-3 | bash
          fi

          # k9s - Kubernetes Terminal UI (Great addition!)
          if ! command -v k9s >/dev/null; then
            curl -sS https://webinstall.dev/k9s | bash
          fi

          # kubectl completion
          if command -v kubectl >/dev/null; then
            kubectl completion bash > /etc/bash_completion.d/kubectl || true
            echo 'source /etc/bash_completion.d/kubectl' >> /home/vagrant/.bashrc
            echo 'source /etc/bash_completion.d/kubectl' >> /root/.bashrc
          fi

          # K3s
          if ! command -v k3s >/dev/null; then
            curl -sfL https://get.k3s.io | INSTALL_K3S_EXEC="server --write-kubeconfig-mode 644 --disable traefik --node-ip=$MASTER_IP" sh -
          fi

          # ============================================================
          # BULLETPROOF KUBECONFIG
          # ============================================================
          KUBE_PATH="/etc/rancher/k3s/k3s.yaml"
          cat > /etc/profile.d/99-kubeconfig.sh <<EOF
export KUBECONFIG=$KUBE_PATH
alias k=kubectl
EOF
          chmod +x /etc/profile.d/99-kubeconfig.sh

          mkdir -p /home/vagrant/.kube /root/.kube
          ln -sf $KUBE_PATH /home/vagrant/.kube/config
          ln -sf $KUBE_PATH /root/.kube/config
          chown -R vagrant:vagrant /home/vagrant/.kube

          cat >> /home/vagrant/.bashrc <<'EOF'

# Kubernetes Environment - Bulletproof
source /etc/profile.d/99-kubeconfig.sh
EOF
          chown vagrant:vagrant /home/vagrant/.bashrc

          # Token for workers
          cp /var/lib/rancher/k3s/server/token /vagrant/k3s-token 2>/dev/null || true
          chmod 644 /vagrant/k3s-token 2>/dev/null || true

          # Wait for K3s
          export KUBECONFIG=$KUBE_PATH
          until kubectl get ns kube-system >/dev/null 2>&1; do
            echo "Waiting for K3s..."
            sleep 5
          done

          # SAFE ARGOCD FIX
          kubectl create namespace argocd --dry-run=client -o yaml | kubectl apply -f - || true
          sleep 10

          kubectl get deployment -n argocd argocd-applicationset-controller >/dev/null 2>&1 && \
          kubectl -n argocd rollout restart deployment argocd-applicationset-controller || true

          kubectl get configmap -n argocd argocd-cmd-params-cm >/dev/null 2>&1 && \
          kubectl -n argocd patch configmap argocd-cmd-params-cm \
          --type merge \
          -p '{"data":{"applicationsetcontroller.enable.policy":"false"}}' || true

          echo "====================================="
          echo " LAB READY - FULL DEVSECOPS ENVIRONMENT "
          echo " (k9s, Helm, Rich Image Cache, etc.)   "
          echo "====================================="
        SHELL

      elsif name.start_with?("worker")
        vm.vm.provision "shell", inline: <<-'SHELL'
          set -euo pipefail
          until [ -f /vagrant/k3s-token ]; do sleep 5; done
          until curl -s -k https://192.168.56.10:6443 >/dev/null; do sleep 5; done

          curl -sfL https://get.k3s.io | \
            K3S_URL="https://192.168.56.10:6443" \
            K3S_TOKEN=$(cat /vagrant/k3s-token) sh -

          echo "WORKER READY"
        SHELL
      end
    end
  end
end
K8S_API_HOST_PORT = ENV['K8S_API_HOST_PORT'] || '16443'
DEBUG = ENV['DEBUG'] || 'false'

# Cache mode: 'zero' (no local images) or 'airgap' (keep Harbor cache)
CACHE_MODE = ENV['CACHE_MODE'] || 'zero'

# PINNED VERSIONS
HARBOR_CHART_VERSION = "1.14.0"

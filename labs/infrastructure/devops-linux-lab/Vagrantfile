# -*- mode: ruby -*-
# vi: set ft=ruby :

ENV['LIBVIRT_DEFAULT_URI'] = 'qemu:///system'
Vagrant.require_version ">= 2.2.0"

DEFAULT_CONFIG = {
  memory: 1024,
  cpus: 1,
  disks: []
}.freeze

def resolve_box(box)
  ENV.fetch("VAGRANT_BOX_#{box.gsub('/', '_').upcase}", box)
end

def configure_libvirt(vm, overrides = {})
  settings = DEFAULT_CONFIG.merge(overrides)

  vm.vm.provider :libvirt do |libvirt|
    libvirt.memory = settings[:memory]
    libvirt.cpus = settings[:cpus]
    libvirt.nested = true
    libvirt.uri = "qemu:///system"
    libvirt.graphics_type = "vnc"
    libvirt.graphics_ip = "127.0.0.1"
  end
end

Vagrant.configure("2") do |config|

  config.vm.synced_folder ".", "/vagrant", disabled: false
  PORT_BASE = ENV.fetch("PORT_BASE", "10000").to_i

  machines = {
    "devops" => {
      box: "bento/ubuntu-24.04",
      ip: "192.168.56.10",
      memory: 8192,
      cpus: 4
    }
  }

  linux_labs = {
    "ubuntu-lab"   => { box: "bento/ubuntu-24.04", ip: "192.168.56.20" },
    "rocky-lab"    => { box: resolve_box("cloud-image/rocky-10"), ip: "192.168.56.21" },
    "alma-lab"     => { box: resolve_box("cloud-image/almalinux-10"), ip: "192.168.56.22" },
    "opensuse-lab" => { box: "opensuse/Leap-15.6", ip: "192.168.56.23" }
  }

  ans_nodes = {
    "ans-node1" => "192.168.56.30",
    "ans-node2" => "192.168.56.31"
  }

  all_hosts = machines.merge(linux_labs).merge(ans_nodes.transform_values { |ip| { ip: ip } })

  hosts_entries = all_hosts.map { |n, d| "#{d[:ip]} #{n}" }.join("\n")

  config.vm.provision "shell", run: "always", inline: <<-SHELL
set -e

START="# LAB START"
END="# LAB END"

sed -i "/$START/,/$END/d" /etc/hosts || true

cat >> /etc/hosts <<EOF

$START
#{hosts_entries}
$END
EOF
SHELL

  (machines.merge(linux_labs)).each do |name, opts|

    config.vm.define name do |vm|

      vm.vm.box = opts[:box]
      vm.vm.hostname = name
      vm.vm.network "private_network", ip: opts[:ip]

      configure_libvirt(vm)

      vm.vm.provision "shell", inline: <<-SHELL
set -euo pipefail

apt-get update -qq
apt-get install -y curl wget git jq vim net-tools python3 python3-pip tmux htop tree ncdu

# =========================
# DEVOPS NODE ONLY
# =========================
if [ "#{name}" = "devops" ]; then

apt-get install -y bash-completion ansible gnupg ca-certificates software-properties-common

# Docker
if ! command -v docker >/dev/null 2>&1; then
  curl -fsSL https://get.docker.com | sh
fi
systemctl enable --now docker
usermod -aG docker vagrant

# kubectl
if ! command -v kubectl >/dev/null 2>&1; then
  curl -LO "https://dl.k8s.io/release/$(curl -Ls https://dl.k8s.io/release/stable.txt)/bin/linux/amd64/kubectl"
  install -m 0755 kubectl /usr/local/bin/kubectl
  rm -f kubectl
fi

# bash completion correct
kubectl completion bash > /etc/bash_completion.d/kubectl || true
echo 'alias k=kubectl' >> /home/vagrant/.bashrc
echo 'complete -F __start_kubectl k' >> /home/vagrant/.bashrc

# k3s (STABLE SINGLE NODE)
if ! command -v k3s >/dev/null 2>&1; then
  curl -sfL https://get.k3s.io | INSTALL_K3S_EXEC="server --write-kubeconfig-mode 644" sh -
fi

export KUBECONFIG=/etc/rancher/k3s/k3s.yaml

until kubectl get nodes >/dev/null 2>&1; do sleep 5; done
kubectl wait --for=condition=Ready nodes --all --timeout=180s || true

# Helm
if ! command -v helm >/dev/null 2>&1; then
  curl -fsSL https://raw.githubusercontent.com/helm/helm/main/scripts/get-helm-3 | bash
fi

helm repo add prometheus-community https://prometheus-community.github.io/helm-charts || true
helm repo add grafana https://grafana.github.io/helm-charts || true
helm repo add ingress-nginx https://kubernetes.github.io/ingress-nginx || true
helm repo add argo https://argoproj.github.io/argo-helm || true
helm repo update

# Metrics server (safe apply)
kubectl apply -f https://github.com/kubernetes-sigs/metrics-server/releases/latest/download/components.yaml || true

# Ingress
helm upgrade --install ingress-nginx ingress-nginx/ingress-nginx \
  --namespace ingress-nginx --create-namespace || true

# Observability (production style)
helm upgrade --install monitoring prometheus-community/kube-prometheus-stack \
  --namespace monitoring --create-namespace || true

# GitOps (FIXED via Helm, no CRD corruption)
helm upgrade --install argocd argo/argo-cd \
  --namespace argocd --create-namespace \
  --set server.service.type=NodePort || true

echo "DEVOPS PLATFORM READY"
fi
SHELL
    end
  end

  ans_nodes.each do |name, ip|
    config.vm.define name do |vm|
      vm.vm.box = "bento/ubuntu-24.04"
      vm.vm.hostname = name
      vm.vm.network "private_network", ip: ip

      configure_libvirt(vm, memory: 1024, cpus: 1)

      vm.vm.provision "shell", inline: <<-SHELL
apt-get update -qq
apt-get install -y python3 openssh-server
systemctl enable --now ssh
SHELL
    end
  end
end
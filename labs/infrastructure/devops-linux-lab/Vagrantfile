# Auto-detect libvirt network
def detect_libvirt_network
  begin
    output = `sudo virsh net-dumpxml vagrant-libvirt 2>/dev/null`
    if $?.success? && !output.empty?
      doc = REXML::Document.new(output)
      ip_element = REXML::XPath.first(doc, "//ip")
      if ip_element
        network = ip_element.attribute('address').value
        prefix = ip_element.attribute('netmask').value
        prefix_length = prefix ? IPAddr.new(prefix).to_i.to_s(2).count('1') : 24
        return "#{network}/#{prefix_length}"
      end
    end
  rescue => e
    puts "Warning: Could not detect vagrant-libvirt network: #{e}"
  end
  begin
    output = `sudo virsh net-dumpxml default 2>/dev/null`
    if $?.success? && !output.empty?
      doc = REXML::Document.new(output)
      ip_element = REXML::XPath.first(doc, "//ip")
      if ip_element
        network = ip_element.attribute('address').value
        prefix = ip_element.attribute('netmask').value
        prefix_length = prefix ? IPAddr.new(prefix).to_i.to_s(2).count('1') : 24
        return "#{network}/#{prefix_length}"
      end
    end
  rescue => e
    puts "Warning: Could not detect default network: #{e}"
  end
  "192.168.121.0/24"
end

LIBVIRT_NETWORK = detect_libvirt_network
puts "Using libvirt network: #{LIBVIRT_NETWORK}"
network_parts = LIBVIRT_NETWORK.split('/')
NETWORK_BASE = network_parts[0].split('.')[0..2].join('.')
def vm_ip(octet)
  "#{NETWORK_BASE}.#{octet}"
end

MASTER_IP = vm_ip(114)
File.write("/tmp/lab.env", "MASTER_IP=#{MASTER_IP}\nNETWORK_BASE=#{NETWORK_BASE}\n")

# =============================================================================
# HARBOR PASSWORD HANDLING - Simple ENV based approach
# =============================================================================
#
# This is the correct way to handle Harbor password in Vagrant.
# No Ruby command detection - just use the environment variable.
#
# The password must be set in the environment before running vagrant:
#   export HARBOR_PASS='YourStrongPassword'
#   vagrant up
#
# Or use the manager script which handles prompting and passing the variable.
#
# =============================================================================

# Get password from environment
HARBOR_PASS = ENV['HARBOR_PASS']

# Check if we need the password (only if HARBOR_PASS is not set)
if HARBOR_PASS.nil? || HARBOR_PASS.empty?
  # Check if we're running interactively and this looks like a provisioning command
  if $stdin.tty? && ARGV.any? { |arg| arg == 'up' || arg == 'provision' || arg == 'reload' }
    # Only prompt if this looks like a provisioning command
    if ARGV.include?('--provision') || ARGV.include?('provision')
      puts "\n" + "="*60
      puts "  HARBOR REGISTRY PASSWORD REQUIRED"
      puts "="*60
      puts ""
      puts "Harbor container registry will be available at: https://#{MASTER_IP}:30001"
      puts "Please set an admin password for Harbor."
      puts "The password must be at least 8 characters long."
      puts ""
      
      begin
        # Prompt for password using io/console (no echo)
        print "Enter Harbor admin password: "
        password = STDIN.noecho(&:gets).chomp
        puts ""
        
        if password.nil? || password.empty?
          abort("ERROR: Password cannot be empty.")
        end
        
        if password.length < 8
          puts "WARNING: Password is less than 8 characters. This is not recommended."
          print "Continue with weak password? (y/N): "
          confirm = STDIN.gets.chomp.downcase
          unless confirm == 'y' || confirm == 'yes'
            abort("Password creation cancelled.")
          end
        end
        
        print "Confirm password: "
        confirm_password = STDIN.noecho(&:gets).chomp
        puts ""
        
        if password != confirm_password
          abort("ERROR: Passwords do not match.")
        end
        
        ENV['HARBOR_PASS'] = password
        HARBOR_PASS = password
        puts "Password configured successfully."
        puts "="*60
        puts ""
        
      rescue Interrupt
        puts "\nPassword input cancelled."
        exit 1
      end
    else
      # Not a provisioning command, just use placeholder
      ENV['HARBOR_PASS'] = 'PLACEHOLDER_FOR_PARSING'
      HARBOR_PASS = 'PLACEHOLDER_FOR_PARSING'
      puts "Note: HARBOR_PASS not set. This is fine for this command."
      puts "      Password will be required for provisioning."
    end
  else
    # Non-interactive mode - use placeholder
    ENV['HARBOR_PASS'] = 'PLACEHOLDER_FOR_PARSING'
    HARBOR_PASS = 'PLACEHOLDER_FOR_PARSING'
  end
end

